(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '\/MultiTool OD' *)
TYPE UpDnJoystick:
STRUCT
	MaxPosition:UINT := 900;(* 0.1% *)
	MidPosition:UINT := 500;(* 0.1% *)
	MinPosition:UINT := 100;(* 0.1% *)
	Deadband:BYTE := 3;(* % *)
	ProgressionPosDir:BYTE := 0;
	ProgressionNegDir:BYTE := 0;
	ErrorTolerance:INT := 0;(* 0.1% *)
	ErrorDelay:UINT := 500;(* ms *)
END_STRUCT
END_TYPE
(* @END_DECLARATION := '0' *)

(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '\/MultiTool OD' *)
TYPE AngleSensor:
STRUCT
	HighSensorValue:UINT := 450;(* 0.01V *)
	LowSensorValue:UINT := 50;(* 0.01V *)
	HighCalibratedValue:INT := 1800;
	LowCalibratedValue:INT := -1800;
	SensorValueErrorLimitHigh:UINT := 480;(* 0.01V *)
	SensorValueErrorLimitLow:UINT := 20;(* 0.01V *)
	CalibratedValueAlarmLimitHigh:INT := 900;
	CalibratedValueWarningLimitHigh:INT := 450;
	CalibratedValueWarningLimitLow:INT := -450;
	CalibratedValueAlarmLimitLow:INT := -900;
	EnableSensorValueErrors:BOOL := TRUE;(* T/F *)
	EnableCalibratedValueHighAlarm:BOOL := TRUE;(* T/F *)
	EnableCalibratedValueHighWarning:BOOL := TRUE;(* T/F *)
	EnableCalibratedValueLowWarning:BOOL := TRUE;(* T/F *)
	EnableCalibratedValueLowAlarm:BOOL := TRUE;(* T/F *)
	ErrorDelay:UINT := 1000;(* ms *)
END_STRUCT
END_TYPE
(* @END_DECLARATION := '0' *)

(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '\/MultiTool OD' *)
TYPE UpDnPairValve:
STRUCT
	PosDirMaxCurrent:UINT := 150;(* mA *)
	PosDirMinCurrent:UINT := 30;(* mA *)
	NegDirMaxCurrent:UINT := 150;(* mA *)
	NegDirMinCurrent:UINT := 30;(* mA *)
	PosDirAscendRamp:UINT := 300;(* ms *)
	PosDirDescendRamp:UINT := 300;(* ms *)
	NegDirAscendRamp:UINT := 300;(* ms *)
	NegDirDescendRamp:UINT := 300;(* ms *)
	PosDirAttenuationAmount:BYTE := 0;(* % *)
	NegDirAttenuationAmount:BYTE := 0;(* % *)
	EnableCounterControl:BOOL := TRUE;(* T/F *)
END_STRUCT
END_TYPE
(* @END_DECLARATION := '0' *)

(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '\/MultiTool OD' *)
TYPE Regulation:
STRUCT
	ValveUpLimit:INT := 0;
	ValveDnLimit:INT := 0;
END_STRUCT
