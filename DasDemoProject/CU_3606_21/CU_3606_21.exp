	G_InitEntryReady:=TRUE;
END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Entry TO Init_Flash:=
G_InitEntryReady
END_TRANSITION
INITIAL_STEP Init_Flash:7
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
G_InitFlashReady := FALSE;

IF G_3606_NvLoadStarted = FALSE THEN
	NvRam_3606_Init(i_Enable :=TRUE, i_KeyWordFastParams := G_FileSysKeyWord, i_SizeOfParams := G_3606_PARAM_SIZE, i_SizeOfFastParams := G_3606_FAST_PARAM_SIZE);
	G_3606_NvLoadStarted := TRUE;
ELSE
	NvRam_3606_Init();

	(* Flash init ready exit from block *)
	IF NvRam_3606_Init.o_InitDone = TRUE THEN

	  G_3606_ErrFastParamsLoad := NvRam_3606_Init.o_ErrorFastParams;
	  G_3606_ErrParamsLoad := NvRam_3606_Init.o_ErrorParams;

	  FileSysInit(
			  i_FileSysKey:=G_FileSysKeyWord ,
			  i_pStart:= ADR(G_3606_ParameterImage[3]) ,                      (* Image contains footer and header. *)
			  i_pEnd:=  ADR(G_3606_ParameterImage[G_3606_PARAM_SIZE-2]),
			  i_BlockSize:= G_3606_BLOCK_SIZE_FILE_SYS ,
			  o_Error=> G_3606_ErrFileSysInit);
	      G_FileSysDir := G_FileSysFileSystem.Dir;
		   (* Store old ram image changed counter *)
		G_3606_OldImageChanged := G_FileSysFileSystem.RamImageChanged;
		G_InitFlashReady := TRUE;
	END_IF

END_IF

END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Flash TO Init_IO:=
G_InitFlashReady
END_TRANSITION
INITIAL_STEP Init_IO:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
	;
(*IO init:*)
    (* System inits *)
    SYSTEM_FW_VERSION:=SystemParameters.o_SoftwareVersion;
    SYSTEM_ControlUnitType := SystemParameters.o_ProductCode;
    SYSTEM_ControlUnitRevision := SystemParameters.o_RevisionNumber;
    SYSTEM_SerialNumber := SystemParameters.o_SerialNumber;
    SYSTEM_VendorId := SystemParameters.o_VendorId;

(* Enabled 5V reference as default *)
    REF_OUT_5V_Enable := TRUE;

(* Init conversion array for supply voltage measurement *)
    G_AIBufferOf_SupplyVolt.i_CH:= 3;
    G_AIBufferOf_SupplyVolt.i_Data := ADR(AI_ARR_SupplyVolt);
    G_AIBufferOf_SupplyVolt.i_Length := SIZEOF(AI_ARR_SupplyVolt);
    G_AIBufferOf_SupplyVolt();

(* Init conversion array for PCB temperature measurement *)
    G_AIBufferOf_PcbTemperature.i_CH:= 2;
    G_AIBufferOf_PcbTemperature.i_Data := ADR(AI_ARR_PCBTemperature);
    G_AIBufferOf_PcbTemperature.i_Length := SIZEOF(AI_ARR_PCBTemperature);
    G_AIBufferOf_PcbTemperature();

(* Init conversion array 5V reference voltage measurement *)
    G_AIBufferOf_Ref5V.i_CH:= 0;
    G_AIBufferOf_Ref5V.i_Data := ADR(AI_ARR_Ref5V);
    G_AIBufferOf_Ref5V.i_Length := SIZEOF(AI_ARR_Ref5V);
    G_AIBufferOf_Ref5V();

(* Init conversion array 2.5V reference voltage  measurement *)
    G_AIBufferOf_Ref2_5V.i_CH:= 1;
    G_AIBufferOf_Ref2_5V.i_Data := ADR(AI_ARR_Ref2_5V);
    G_AIBufferOf_Ref2_5V.i_Length := SIZEOF(AI_ARR_Ref2_5V);
    G_AIBufferOf_Ref2_5V();


(* Configurations for pin 1.2 *)

    (* Use pin as Pwfm Output *)
    PWFM_ERROR_VAVLE_UP := IO_PWFM_SET_CONFIG(
                  i_PwfmMode := IO_PWFM_MODE_DIRECT_PWFM,
                  i_PwfmChn := 1);
   IF NOT ( PWFM_ERROR_VAVLE_UP = 0 ) THEN
         ERR_FLAG_IO_INIT := TRUE;
    END_IF
    PWM_RATIO_VAVLE_UP :=  0; (* Set ratio as 0 in init. *)
    PWFM_FREQ_VAVLE_UP := 140;(* Set default frequency. *)


(* Configurations for pin 1.3 *)

    (* Use pin as Pwfm Output *)
    PWFM_ERROR_VAVLE_DN := IO_PWFM_SET_CONFIG(
                  i_PwfmMode := IO_PWFM_MODE_DIRECT_PWFM,
                  i_PwfmChn := 2);
   IF NOT ( PWFM_ERROR_VAVLE_DN = 0 ) THEN
         ERR_FLAG_IO_INIT := TRUE;
    END_IF
    PWM_RATIO_VAVLE_DN :=  0; (* Set ratio as 0 in init. *)
    PWFM_FREQ_VAVLE_DN := 140;(* Set default frequency. *)


(* Configurations for pin 1.7 *)

    (* Use pin as Digital Output *)
    DO_ERROR_LED1 := IO_PWFM_SET_CONFIG(
                  i_PwfmMode := IO_PWFM_MODE_DIGITAL_OUTPUT,
                  i_PwfmChn := 3);
   IF NOT ( DO_ERROR_LED1 = 0 ) THEN
         ERR_FLAG_IO_INIT := TRUE;
    END_IF
    DO_LED1 :=  0; (* Set output as 0 in init. *)


(* Configurations for pin 1.8 *)

    (* Use pin as Digital Output *)
    DO_ERROR_LED2 := IO_PWFM_SET_CONFIG(
                  i_PwfmMode := IO_PWFM_MODE_DIGITAL_OUTPUT,
                  i_PwfmChn := 4);
   IF NOT ( DO_ERROR_LED2 = 0 ) THEN
         ERR_FLAG_IO_INIT := TRUE;
    END_IF
    DO_LED2 :=  0; (* Set output as 0 in init. *)


(* Configurations for pin 1.9 *)


(* Configurations for pin 1.10 *)


(* Configurations for pin 1.11 *)


(* Configurations for pin 1.12 *)


(* Configurations for pin 1.14 *)


(* Configurations for pin 1.15 *)

(* Update Functions for pin 1.20 *)

(* Set AI mode for pin 1.20 *)
    AI_SET_mA_JOYSTICK_MV := FALSE;


(* Mean filtering for pin 1.20 *)
    G_AIBufferOf_JOYSTICK_MV.i_CH:= 11;
    G_AIBufferOf_JOYSTICK_MV.i_Data := ADR(AI_ARR_JOYSTICK_MV);
    G_AIBufferOf_JOYSTICK_MV.i_Length := SIZEOF(AI_ARR_JOYSTICK_MV);
    G_AIBufferOf_JOYSTICK_MV();


(* Set AI mode for pin 1.21 *)
    AI_SET_mA_SENSOR_MV := FALSE;


(* Mean filtering for pin 1.21 *)
    G_AIBufferOf_SENSOR_MV.i_CH:= 10;
    G_AIBufferOf_SENSOR_MV.i_Data := ADR(AI_ARR_SENSOR_MV);
    G_AIBufferOf_SENSOR_MV.i_Length := SIZEOF(AI_ARR_SENSOR_MV);
    G_AIBufferOf_SENSOR_MV();



(* Configurations for pin 1.22 *)
   (* Init array where is 50 latest conversion result for feedback *)
   G_AIBufferOf_VALVE_UPDN_CURRENT.i_CH:= 6;
   G_AIBufferOf_VALVE_UPDN_CURRENT.i_Data := ADR(AI_ARR_VALVE_UPDN_CURRENT);
   G_AIBufferOf_VALVE_UPDN_CURRENT.i_Length := SIZEOF(AI_ARR_VALVE_UPDN_CURRENT);
   G_AIBufferOf_VALVE_UPDN_CURRENT();


(* Configurations for pin 1.25 *)


(* Configurations for pin 1.26 *)


(* Configurations for pin 1.27 *)

	(* tag INIT_INIT_IO *)

(* Init for overcurrent protection for mA AI inputs *)
AIP_InputProtection_3606(); (* 3606 Analog overcurrent input protection init *)

(*IO-init OK?*)
	G_InitIOReady:=TRUE;
END_STEP


(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_IO TO Init_Bus:=
G_InitIOReady
END_TRANSITION
INITIAL_STEP Init_Bus:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
	;
	CANVXDInitCAN(i_DrvNbr:=0, i_BitRate:=250, i_Flags:=(G_CANVXD_FLAGS_AUTORECOVERY OR G_CANVXD_FLAGS_11BIT_OPTIMIZED));




(*IO-init OK?*)
	G_InitBusReady:=TRUE;
END_STEP

(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Bus TO Init_Protocols_Can1:=
G_InitBusReady
END_TRANSITION

INITIAL_STEP Init_Protocols_Can1:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
	;

(*CAN1 INIT*)
(* Sequencer is used to split init to smaller steps *)
CASE CANInitSequencer OF
	0: (* Sequencer step 0*)
	G_CAN1_CANopenDevice.DrvNbr:=0;(*Connect device to can channel*)
	G_CAN1_CANopenDevice.NodeID := 1;
	OD_G_CAN1_Comms[10] := 1; (* Node-ID that is not taken from flash *)
	OD_G_CAN1_Comms[3] := 250; (* Bitrate that is not taken from flash *)
	G_CAN1_CANopenDevice_NMT.NmtState:=5;
	G_CAN1_CANopenDevice_NMT.HeartBeat.PT:=T#200ms;(*Optional: Change manually heartbeat producer time (default 0=no heartbeat)*)
	CANopenSystemAddDevice(i_pDev:=ADR(G_CAN1_CANopenDevice));(*Connect device to system*)

(*Initialize OD's datastructures*)

	G_CAN1_CANopenDevice_OD.EntryCount:=SIZEOF(G_CAN1_CANopenDevice_ODEntrys)/SIZEOF(G_CAN1_CANopenDevice_ODEntrys[1]);(*Max entries of given OD(CANopenDeviceODEntrys array)*)
	G_CAN1_CANopenDevice_OD.InOrder:=FALSE;(*OD isn't in order*)
	G_CAN1_CANopenDevice_OD.NextFree:=0;(*OD does not have any entries yet*)
	G_CAN1_CANopenDevice_OD.OD:=ADR(G_CAN1_CANopenDevice_ODEntrys); (*Pointer to OD array*)


(*Define NMT protocol*)

	G_CAN1_CANopenDevice_Protocols[1].ProtocolType:=NMT;
	G_CAN1_CANopenDevice_Protocols[1].Data:=ADR(G_CAN1_CANopenDevice_NMT);
	G_CAN1_CANopenDevice_Protocols[1].pDevice:=ADR(G_CAN1_CANopenDevice);
	G_CAN1_CANopenDevice_Protocols[1].Init:=INDEXOF(CANopenNMTCLIENT.Init);
	G_CAN1_CANopenDevice_Protocols[1].Update:=INDEXOF(CANopenNMTCLIENT.Update);
	CANopenDeviceAddProtocol(i_pDev:=ADR(G_CAN1_CANopenDevice), i_pProtocol:=ADR(G_CAN1_CANopenDevice_Protocols[1]));(*Add defined protocol to device*)

(*Define SSDO protocol*)

	G_CAN1_CANopenDevice_Protocols[2].ProtocolType:=SSDO;
	G_CAN1_CANopenDevice_Protocols[2].Data:=ADR(G_CAN1_CANopenDevice_SSDO);
	G_CAN1_CANopenDevice_Protocols[2].pDevice:=ADR(G_CAN1_CANopenDevice);
	G_CAN1_CANopenDevice_Protocols[2].Init:=INDEXOF(CANopenSDOServer.Init);
	G_CAN1_CANopenDevice_Protocols[2].Update:=INDEXOF(CANopenSDOServer.Update);
	CANopenDeviceAddProtocol(i_pDev:=ADR(G_CAN1_CANopenDevice), i_pProtocol:=ADR(G_CAN1_CANopenDevice_Protocols[2]));(*Add defined protocol to device*)

(*Define OD protocol*)

	G_CAN1_CANopenDevice_Protocols[3].ProtocolType:=OD;
	G_CAN1_CANopenDevice_Protocols[3].Data:=ADR(G_CAN1_CANopenDevice_OD);
	G_CAN1_CANopenDevice_Protocols[3].pDevice:=ADR(G_CAN1_CANopenDevice);
	G_CAN1_CANopenDevice_Protocols[3].Init:=0;
	G_CAN1_CANopenDevice_Protocols[3].Update:=0;
	CANopenDeviceAddProtocol(i_pDev:=ADR(G_CAN1_CANopenDevice), i_pProtocol:=ADR(G_CAN1_CANopenDevice_Protocols[3]));(*Add defined protocol to device*)

(*Define TPDO protocol*)

	G_CAN1_CANopenDevice_Protocols[4].ProtocolType:=TPDO;
	G_CAN1_CANopenDevice_Protocols[4].Data:=ADR(G_CAN1_CANopenDevice_TPDODesc);
	G_CAN1_CANopenDevice_Protocols[4].pDevice:=ADR(G_CAN1_CANopenDevice);
	G_CAN1_CANopenDevice_Protocols[4].Init:=0;
	G_CAN1_CANopenDevice_Protocols[4].Update:=INDEXOF(CANopenPDOSend);
	CANopenDeviceAddProtocol(i_pDev:=ADR(G_CAN1_CANopenDevice), i_pProtocol:=ADR(G_CAN1_CANopenDevice_Protocols[4]));(*Add defined protocol to device*)

(*Define RPDO protocol*)

	G_CAN1_CANopenDevice_Protocols[5].ProtocolType:=RPDO;
	G_CAN1_CANopenDevice_Protocols[5].Data:=ADR(G_CAN1_CANopenDevice_RPDODesc);
	G_CAN1_CANopenDevice_Protocols[5].pDevice:=ADR(G_CAN1_CANopenDevice);
	G_CAN1_CANopenDevice_Protocols[5].Init:=0;
	G_CAN1_CANopenDevice_Protocols[5].Update:=INDEXOF(CANopenPDORead);
	CANopenDeviceAddProtocol(i_pDev:=ADR(G_CAN1_CANopenDevice), i_pProtocol:=ADR(G_CAN1_CANopenDevice_Protocols[5]));(*Add defined protocol to device*)

(*Define SYNC protocol*)

	G_CAN1_CANopenDevice_Protocols[6].ProtocolType:=SYNC;
	G_CAN1_CANopenDevice_Protocols[6].Data:=ADR(G_CAN1_CANopenDevice_SYNC);
	G_CAN1_CANopenDevice_Protocols[6].pDevice:=ADR(G_CAN1_CANopenDevice);
	G_CAN1_CANopenDevice_Protocols[6].Init:=INDEXOF(CANopenSYNCProtocol.Init);
	G_CAN1_CANopenDevice_Protocols[6].Update:=0;
	CANopenDeviceAddProtocol(i_pDev:=ADR(G_CAN1_CANopenDevice), i_pProtocol:=ADR(G_CAN1_CANopenDevice_Protocols[6]));(*Add defined protocol to device*)

(*Define HBCons protocol*)

	G_CAN1_CANopenDevice_Protocols[7].ProtocolType:=HBCons;
	G_CAN1_CANopenDevice_Protocols[7].Data:=ADR(G_CAN1_CANopenDevice_HBConsumer);
	G_CAN1_CANopenDevice_Protocols[7].pDevice:=ADR(G_CAN1_CANopenDevice);
	G_CAN1_CANopenDevice_Protocols[7].Init:=INDEXOF(CANopenHBConsumer.Init);
	G_CAN1_CANopenDevice_Protocols[7].Update:=INDEXOF(CANopenHBConsumer.Update);
	CANopenDeviceAddProtocol(i_pDev:=ADR(G_CAN1_CANopenDevice), i_pProtocol:=ADR(G_CAN1_CANopenDevice_Protocols[7]));(*Add defined protocol to device*)



		CANInitSequencer := CANInitSequencer + 1;
	1: (* Sequencer step 1*)
(* Init network manager *)

	G_CAN1_NetworkManager.Init(
		i_ThisIsMaster:=TRUE,
		i_DrvNbr:=0,
		i_StartInterval:=1000,
		i_pMonitoredNodes:=0,
		i_NumberOfNodes:=0);

		CANInitSequencer := CANInitSequencer + 1;
	2: (* Sequencer step 2*)
(*INIT CAN1 OD*)

	CANopenODAddLine(ADR(G_CAN1_CANopenDevice_OD), 16#0001, OD_DEFTYPE, 0, 0, 16#28, 0, 1, 0);(*typedef U1*)
	CANopenODAddLine(ADR(G_CAN1_CANopenDevice_OD), 16#0002, OD_DEFTYPE, 0, 0, 16#28, 0, 8, 0);(*typedef I8*)
	CANopenODAddLine(ADR(G_CAN1_CANopenDevice_OD), 16#0003, OD_DEFTYPE, 0, 0, 16#28, 0, 16, 0);(*typedef I16*)
	CANopenODAddLine(ADR(G_CAN1_CANopenDevice_OD), 16#0004, OD_DEFTYPE, 0, 0, 16#28, 0, 32, 0);(*typedef I32*)
	CANopenODAddLine(ADR(G_CAN1_CANopenDevice_OD), 16#0005, OD_DEFTYPE, 0, 0, 16#28, 0, 8, 0);(*typedef U8*)
	CANopenODAddLine(ADR(G_CAN1_CANopenDevice_OD), 16#0006, OD_DEFTYPE, 0, 0, 16#28, 0, 16, 0);(*typedef U16*)
	CANopenODAddLine(ADR(G_CAN1_CANopenDevice_OD), 16#0007, OD_DEFTYPE, 0, 0, 16#28, 0, 32, 0);(*typedef U32*)
	CANopenODAddLine(ADR(G_CAN1_CANopenDevice_OD), 16#0008, OD_DEFTYPE, 0, 0, 16#28, 0, 32, 0);(*typedef of real*)
	CANopenODAddLine(ADR(G_CAN1_CANopenDevice_OD), 16#0009, OD_DEFTYPE, 0, 0, 16#28, 0, 80*8, 0);(*typedef str*)

	(*Struct type definition - index: 40, variable: 'G_CAN1_DEFSTRUCT_DATATYPES_40h'*)
	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#0040,
		i_ObjectCode:=OD_DEFSTRUCT,(*Type of index*)
		i_NumOfSubids:=0,(*Typedef does not have subindexes*)
		i_TypeSpec:=0,(*Type definition itself doesn't need type definition*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_NOWRITE+G_CANOPEN_OD_ACCESS_SUB0NOWRITE,
		i_sub0data:=0,(*Typedef does not have subindexes*)
		i_pIndexData:=ADR(G_CAN1_DEFSTRUCT_DATATYPES_40h),(*Bit length of type*)
		i_CallBackPOU:=0);(*No callback POU*)

	(*Struct type definition - index: 41, variable: 'G_CAN1_DEFSTRUCT_DATATYPES_41h'*)
	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#0041,
		i_ObjectCode:=OD_DEFSTRUCT,(*Type of index*)
		i_NumOfSubids:=0,(*Typedef does not have subindexes*)
		i_TypeSpec:=0,(*Type definition itself doesn't need type definition*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_NOWRITE+G_CANOPEN_OD_ACCESS_SUB0NOWRITE,
		i_sub0data:=0,(*Typedef does not have subindexes*)
		i_pIndexData:=ADR(G_CAN1_DEFSTRUCT_DATATYPES_41h),(*Bit length of type*)
		i_CallBackPOU:=0);(*No callback POU*)

	(*Struct type definition - index: 42, variable: 'G_CAN1_DEFSTRUCT_DATATYPES_42h'*)
	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#0042,
		i_ObjectCode:=OD_DEFSTRUCT,(*Type of index*)
		i_NumOfSubids:=0,(*Typedef does not have subindexes*)
		i_TypeSpec:=0,(*Type definition itself doesn't need type definition*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_NOWRITE+G_CANOPEN_OD_ACCESS_SUB0NOWRITE,
		i_sub0data:=0,(*Typedef does not have subindexes*)
		i_pIndexData:=ADR(G_CAN1_DEFSTRUCT_DATATYPES_42h),(*Bit length of type*)
		i_CallBackPOU:=0);(*No callback POU*)

	(*Struct type definition - index: 43, variable: 'G_CAN1_DEFSTRUCT_DATATYPES_43h'*)
	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#0043,
		i_ObjectCode:=OD_DEFSTRUCT,(*Type of index*)
		i_NumOfSubids:=0,(*Typedef does not have subindexes*)
		i_TypeSpec:=0,(*Type definition itself doesn't need type definition*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_NOWRITE+G_CANOPEN_OD_ACCESS_SUB0NOWRITE,
		i_sub0data:=0,(*Typedef does not have subindexes*)
		i_pIndexData:=ADR(G_CAN1_DEFSTRUCT_DATATYPES_43h),(*Bit length of type*)
		i_CallBackPOU:=0);(*No callback POU*)


	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#1000,
		i_ObjectCode:=OD_VAR,(*Type of index*)
		i_NumOfSubids:=0,(*Number of subindexes*)
		i_TypeSpec:=16#0007,(*Index datatype, either user defined or standard CiA 301*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_NOWRITE OR G_CANOPEN_OD_ACCESS_SUB0NOWRITE,
		i_sub0data:=0,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(OD_DeviceType_Device1),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#1001,
		i_ObjectCode:=OD_VAR,(*Type of index*)
		i_NumOfSubids:=0,(*Number of subindexes*)
		i_TypeSpec:=16#0005,(*Index datatype, either user defined or standard CiA 301*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_NOWRITE OR G_CANOPEN_OD_ACCESS_SUB0NOWRITE,
		i_sub0data:=0,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(OD_ErrorReg_Device1),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#100a,
		i_ObjectCode:=OD_VAR,(*Type of index*)
		i_NumOfSubids:=0,(*Number of subindexes*)
		i_TypeSpec:=16#0009,(*Index datatype, either user defined or standard CiA 301*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_NOWRITE OR G_CANOPEN_OD_ACCESS_SUB0NOWRITE,
		i_sub0data:=0,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(SystemParameters.o_SoftwareVersion),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#1017,
		i_ObjectCode:=OD_VAR,(*Type of index*)
		i_NumOfSubids:=0,(*Number of subindexes*)
		i_TypeSpec:=16#0006,(*Index datatype, either user defined or standard CiA 301*)
		i_ObjectAccess:=0,
		i_sub0data:=0,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(G_CAN1_CANopenDevice_NMT.HeartBeat.PT),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#1018,
		i_ObjectCode:=OD_ARRAY, (*Type of index*)
		i_NumOfSubids:=4,(*Number of subindexes*)
		i_TypeSpec:=16#0007,(*Index of 16-bit deftype*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_NOWRITE OR G_CANOPEN_OD_ACCESS_SUB0NOWRITE,
		i_sub0data:=4,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(OD_IdentityArray_Device),
		i_CallBackPOU:=0);
	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#2129,
		i_ObjectCode:=OD_VAR,(*Type of index*)
		i_NumOfSubids:=0,(*Number of subindexes*)
		i_TypeSpec:=16#0005,(*Index datatype, either user defined or standard CiA 301*)
		i_ObjectAccess:=0,
		i_sub0data:=0,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(OD_CAN1_PDO_DUMMY),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#2130,
		i_ObjectCode:=OD_ARRAY, (*Type of index*)
		i_NumOfSubids:=10,(*Number of subindexes*)
		i_TypeSpec:=16#0009,(*Index of 16-bit deftype*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_NOWRITE OR G_CANOPEN_OD_ACCESS_SUB0NOWRITE,
		i_sub0data:=10,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(OD_SoftwareInformation),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#2131,
		i_ObjectCode:=OD_VAR,(*Type of index*)
		i_NumOfSubids:=0,(*Number of subindexes*)
		i_TypeSpec:=16#0006,(*Index datatype, either user defined or standard CiA 301*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_NOWRITE OR G_CANOPEN_OD_ACCESS_SUB0NOWRITE,
		i_sub0data:=0,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(OD_Parameter_CSV_unique_ID1),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#2150,
		i_ObjectCode:=OD_ARRAY, (*Type of index*)
		i_NumOfSubids:=10,(*Number of subindexes*)
		i_TypeSpec:=16#0006,(*Index of 16-bit deftype*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_SUB0NOWRITE,
		i_sub0data:=10,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(OD_G_CAN1_Comms),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#2200,
		i_ObjectCode:=OD_RECORD,(*Type of index*)
		i_NumOfSubids:=8,(*Number of subindexes*)
		i_TypeSpec:=16#0040,(*Index of 16-bit deftype*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_SUB0NOWRITE OR G_CANOPEN_OD_ACCESS_SAVE,
		i_sub0data:=8,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(PAR_UpDnJoystick),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#2201,
		i_ObjectCode:=OD_RECORD,(*Type of index*)
		i_NumOfSubids:=16,(*Number of subindexes*)
		i_TypeSpec:=16#0041,(*Index of 16-bit deftype*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_SUB0NOWRITE OR G_CANOPEN_OD_ACCESS_SAVE,
		i_sub0data:=16,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(PAR_AngleSensor),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#2202,
		i_ObjectCode:=OD_RECORD,(*Type of index*)
		i_NumOfSubids:=11,(*Number of subindexes*)
		i_TypeSpec:=16#0042,(*Index of 16-bit deftype*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_SUB0NOWRITE OR G_CANOPEN_OD_ACCESS_SAVE,
		i_sub0data:=11,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(PAR_UpDnPairValve),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#2204,
		i_ObjectCode:=OD_RECORD,(*Type of index*)
		i_NumOfSubids:=2,(*Number of subindexes*)
		i_TypeSpec:=16#0043,(*Index of 16-bit deftype*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_SUB0NOWRITE OR G_CANOPEN_OD_ACCESS_SAVE,
		i_sub0data:=2,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(PAR_Regulation),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#5fdf,
		i_ObjectCode:=OD_ARRAY,(*Type of index*)
		i_NumOfSubids:=3,(*Number of subindexes*)
		i_TypeSpec:=16#0006,(*Index datatype, either user defined or standard CiA 301*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_SUB0NOWRITE OR G_CANOPEN_OD_ACCESS_PDOMAP,
		i_sub0data:=3,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(CANO_ValveUpPWM),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#5fef,
		i_ObjectCode:=OD_ARRAY,(*Type of index*)
		i_NumOfSubids:=2,(*Number of subindexes*)
		i_TypeSpec:=16#0003,(*Index datatype, either user defined or standard CiA 301*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_SUB0NOWRITE OR G_CANOPEN_OD_ACCESS_PDOMAP,
		i_sub0data:=2,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(CANO_SensorMeter),
		i_CallBackPOU:=0);

	CANopenODAddLine(
		i_pOD:=ADR(G_CAN1_CANopenDevice_OD),(*Address of Object dictionary where index will be added*)
		i_index:=16#5fff,
		i_ObjectCode:=OD_ARRAY,(*Type of index*)
		i_NumOfSubids:=3,(*Number of subindexes*)
		i_TypeSpec:=16#0005,(*Index datatype, either user defined or standard CiA 301*)
		i_ObjectAccess:=G_CANOPEN_OD_ACCESS_SUB0NOWRITE OR G_CANOPEN_OD_ACCESS_PDOMAP,
		i_sub0data:=3,(*Value of subindex0 in array or (def)struct*)
		i_pIndexData:=ADR(CANI_Ctrl),
		i_CallBackPOU:=0);


		CANInitSequencer := CANInitSequencer + 1;
	3:  (* Sequencer step 3*)
(*INIT CAN1 TPDOS*) 

(* TPDO1 *)
	G_CAN1_CANopenDevice_TPDOS[1].i_Mapping[0]:= 16#5fef0210; (*Joystick*)
	G_CAN1_CANopenDevice_TPDOS[1].i_Mapping[1]:= 16#5fef0110; (*SensorMeter*)
	G_CAN1_CANopenDevice_TPDOS[1].i_Mapping[2]:= 16#5fff0208; (*DigitalInput*)
	G_CAN1_CANopenDevice_TPDOS[1].i_Mapping[3]:= 16#5fff0308; (*DigitalOutput*)
	G_CAN1_CANopenDevice_TPDOS[1].Init(
		i_pDevice:= ADR(G_CAN1_CANopenDevice),
		i_PDONumber:= 0,
		i_PDOType:= TransmitPDO,
		i_COB_ID:= G_CAN1_CANopenDevice.NodeID + 16#180,
		i_TransmissionType:= 16#ff,
		i_InhibitTime:= 100,
		i_Reserved:= 0,
		i_EventTime:= 300,
		i_Mappings:= 4);

(* TPDO2 *)
	G_CAN1_CANopenDevice_TPDOS[2].i_Mapping[0]:= 16#5fdf0110; (*ValveUpPWM*)
	G_CAN1_CANopenDevice_TPDOS[2].i_Mapping[1]:= 16#5fdf0210; (*ValveDnPWM*)
	G_CAN1_CANopenDevice_TPDOS[2].i_Mapping[2]:= 16#5fdf0310; (*FeedbackCurrent*)
	G_CAN1_CANopenDevice_TPDOS[2].Init(
		i_pDevice:= ADR(G_CAN1_CANopenDevice),
		i_PDONumber:= 1,
		i_PDOType:= TransmitPDO,
		i_COB_ID:= G_CAN1_CANopenDevice.NodeID + 16#280,
		i_TransmissionType:= 16#ff,
		i_InhibitTime:= 100,
		i_Reserved:= 0,
		i_EventTime:= 300,
		i_Mappings:= 3);


	G_CAN1_CANopenDevice_TPDODesc.pPDO:=ADR(G_CAN1_CANopenDevice_TPDOS);(*connect PDO to Protocoldescritor of TPDO*)
	G_CAN1_CANopenDevice_TPDODesc.Count:=2; (* Amount of TPDOS *)

(*INIT CAN1 RPDOS*) 

(* RPDO1 *)
	G_CAN1_CANopenDevice_RPDOS[1].i_Mapping[0]:= 16#5fff0108; (*Ctrl*)
	G_CAN1_CANopenDevice_RPDOS[1].Init(
		i_pDevice:= ADR(G_CAN1_CANopenDevice),
		i_PDONumber:= 0,
		i_PDOType:= ReceivePDO,
		i_COB_ID:= 16#200,
		i_TransmissionType:= 16#ff,
		i_InhibitTime:= 100,
		i_Reserved:= 0,
		i_EventTime:= 1000,
		i_Mappings:= 1);


	G_CAN1_CANopenDevice_RPDODesc.pPDO:=ADR(G_CAN1_CANopenDevice_RPDOS);(*connect PDO to Protocoldescritor of RPDO*)
	G_CAN1_CANopenDevice_RPDODesc.Count:=1; (* Amount of RPDOS *)


		CANInitSequencer := CANInitSequencer + 1;
	4:   (* Sequencer step 4*)

		CANInitSequencer := CANInitSequencer + 1;
	5:   (* Sequencer step 5*)
(*Initialize OD save*)
	G_CAN1_CANopenDevice_SaveSubData1010h.SaveSigns := ADR(G_CAN1_CANopenDevice_SaveSigns1010[0]);
	G_CAN1_CANopenDevice_SaveSubData1010h.SaveIndexData := ADR(G_CAN1_CANopenDevice_SaveData[0]);
	G_CAN1_CANopenDevice_SaveData[3].CBPOU_SaveAll := INDEXOF(SaveODAll);
	G_CAN1_CANopenDevice_SaveData[3].CBPOU_DeleteAll := INDEXOF(SaveODDeleteAll);
	G_CAN1_CANopenDevice_OD.AdditionalData := ADR(G_CAN1_CANopenDevice_SaveSubData1010h);
	SaveODhndl1010.Init(i_pOD:= ADR(G_CAN1_CANopenDevice_OD));
	SaveODhndl1011.Init(i_pOD:= ADR(G_CAN1_CANopenDevice_OD));
	SaveODLoadODLinesByDesc(ADR(G_CAN1_CANopenDevice_OD),0);

	CANopenODReOrg(i_pOD:=ADR(G_CAN1_CANopenDevice_OD));

		CANInitSequencer := CANInitSequencer + 1;
	ELSE
		(* Sequencer ready *)
		G_InitProtocolsCan1Ready:=TRUE;
		CANInitSequencer := 0;
END_CASE

END_STEP

(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Protocols_Can1 TO Init_Protocols_Can2:=
G_InitProtocolsCan1Ready
END_TRANSITION

INITIAL_STEP Init_Protocols_Can2:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
	;


(*CAN2 INIT*)
(* Sequencer is used to split init to smaller steps *)
CASE CANInitSequencer OF
	0: (* Sequencer step 0*)

		CANInitSequencer := CANInitSequencer + 1;
	1: (* Sequencer step 1*)

		CANInitSequencer := CANInitSequencer + 1;
	2: (* Sequencer step 2*)

		CANInitSequencer := CANInitSequencer + 1;
	3:  (* Sequencer step 3*)

		CANInitSequencer := CANInitSequencer + 1;
	4:   (* Sequencer step 4*)

		CANInitSequencer := CANInitSequencer + 1;
	5:   (* Sequencer step 5*)

		CANInitSequencer := CANInitSequencer + 1;
	ELSE
		(* Sequencer ready *)
		G_InitProtocolsCan2Ready:=TRUE;
		CANInitSequencer := 0;
END_CASE

END_STEP

