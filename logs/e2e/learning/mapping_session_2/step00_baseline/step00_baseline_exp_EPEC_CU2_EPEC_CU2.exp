STEP IOFilter:
;
(* Update Functions for pin 1.2 *)

(* Update Functions for pin 1.3 *)

(* Update Functions for pin 1.7 *)

(* Update Functions for pin 1.8 *)

(* Update Functions for pin 1.9 *)

(* Update Functions for pin 1.10 *)

(* Update Functions for pin 1.11 *)

(* Update Functions for pin 1.12 *)

(* Update Functions for pin 1.14 *)

(* Update Functions for pin 1.15 *)

(* Update Functions for pin 1.25 *)

(* Update Functions for pin 1.26 *)

(* Update Functions for pin 1.27 *)


END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
STEP Diag:

(* Mean filtering for supply voltage measurement *)
    AiSupplyAiFiltArrayIndex:= WORD_TO_BYTE(G_AIBufferOf_SupplyVolt.o_Write);
    AI_SupplyVolt:=AI_MeanValue(
                i_LatestBufferIndex := AiSupplyAiFiltArrayIndex,
                i_pBuffer := G_AIBufferOf_SupplyVolt.i_Data,
                i_FirstIndex := 0,
                i_SizeOfBuffer := 50,
                i_Samples := 10);

(* Mean filtering for PCB temperature measurement *)
    AI_ARR_INDEX_PcbTemperature:= WORD_TO_BYTE(G_AIBufferOf_PcbTemperature.o_Write);
    AI_PCBTemperature:=AI_MeanValue(
                i_LatestBufferIndex := AI_ARR_INDEX_PcbTemperature,
                i_pBuffer := G_AIBufferOf_PcbTemperature.i_Data,
                i_FirstIndex := 0,
                i_SizeOfBuffer := 50,
                i_Samples := 10);

(* Mean filtering for 5V reference voltage measurement *)
    AI_ARR_INDEX_Ref5V:= WORD_TO_BYTE(G_AIBufferOf_Ref5V.o_Write);
    AI_Ref5V:=AI_MeanValue(
                i_LatestBufferIndex := AI_ARR_INDEX_Ref5V,
                i_pBuffer := G_AIBufferOf_Ref5V.i_Data,
                i_FirstIndex := 0,
                i_SizeOfBuffer := 50,
                i_Samples := 10);

(* Mean filtering for 2.5V reference voltage measurement *)
    AI_ARR_INDEX_Ref2_5V:= WORD_TO_BYTE(G_AIBufferOf_Ref2_5V.o_Write);
    AI_Ref2_5V:=AI_MeanValue(
                i_LatestBufferIndex := AI_ARR_INDEX_Ref2_5V,
                i_pBuffer := G_AIBufferOf_Ref2_5V.i_Data,
                i_FirstIndex := 0,
                i_SizeOfBuffer := 50,
                i_Samples := 10);

(* Diagnostic *)
    G_HWDiagnostics(
        i_SupplyVoltage := AI_SupplyVolt,
        i_Ref5V := AI_Ref5V,
        i_Ref2_5V := AI_Ref2_5V,
        i_Temperature := AI_PCBTemperature,
        i_SupplyVoltageHighLimit := G_SupplyVoltageHighLimit,
        i_SupplyVoltageLowLimit := G_SupplyVoltageLowLimit,
        i_Ref5VHighLimit := G_Ref5VHighLimit,
        i_Ref5VLowLimit := G_Ref5VLowLimit,
        i_Ref2_5VHighLimit := G_Ref2V5HighLimit,
        i_Ref2_5VLowLimit := G_Ref2V5LowLimit,
        i_TempHighLimit := G_TempHighLimit,
        i_TempLowLimit := G_TempLowLimit,
        i_CycleTimeHighLimit := G_CycleTimeHighLimit);

    TEMP_PCB := G_HWDiagnostics.o_Temperature;
    SUPPLY_Volt := G_HWDiagnostics.o_SupplyVoltage;
    REF_5V := G_HWDiagnostics.o_Ref5V;
    REF_2_5V := G_HWDiagnostics.o_Ref2_5V;







(*########################################################*)
(*This block is created implicit. Don't add own code here.*)
(*########################################################*)

(* Diagnostics for CAN interfaces *)
G_CAN1_Diagnostics(i_DrvNbr:=0);

(* CANopen networks management and diagnostics  *)
G_CAN1_NetworkManager();

(* System Ok conditions *)
G_SystemOk:=NOT(G_HWDiagnostics.o_TemperatureHigh) AND
		NOT(G_HWDiagnostics.o_TemperatureLow) AND
		NOT(G_HWDiagnostics.o_SupplyVoltageHigh) AND
		NOT(G_HWDiagnostics.o_SupplyVoltageLow) AND
		NOT(G_HWDiagnostics.o_Ref2_5VHigh) AND
		NOT(G_HWDiagnostics.o_Ref2_5VLow) AND
		NOT (ERR_FLAG_IO_INIT);



IO_SET_LED(i_SystemOk:=G_SystemOk, i_RunWithErrors:=G_ActiveError, i_InitState:=NOT(G_InitExitReady));


END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
STEP Bus:
;


	CANVXDCheckMessages();(*Receive CAN-data*)
	CANopenUpdateDevices();(*Updates data of protocols in devices and send CAN-data*)

	(*Check for nmt reset *)
	IF G_CAN1_CANopenDevice_NMT.StateChanged THEN
		IF G_CAN1_CANopenDevice_NMT.LastNmtCommand = 16#81 OR G_CAN1_CANopenDevice_NMT.LastNmtCommand = 16#82 THEN
			(* If there is NMT reset command for IEC application CANopen device,
				IEC application is started after IEC cycle in execution. *)
					G_RESET_MODULE := TRUE;
		END_IF
	END_IF




END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
STEP Other:





END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM (IOFilter,Diag,Bus,Other) TO Init_EpecIn:=
FALSE


END_TRANSITION


END_STEP

STEP Application:
INITIAL_STEP Init_Application:
END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Application TO Main_Application:=
TRUE
END_TRANSITION

STEP Main_Application:
(* Call user application *)
    Main();
END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Main_Application TO Init_Application:=
FALSE
END_TRANSITION
END_STEP

STEP Epec_Out:

INITIAL_STEP Init_EpecOut:


END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_EpecOut TO Other_EpecOut:=
TRUE


END_TRANSITION
STEP Other_EpecOut:


NvRam_3606_Save();

IF NvRam_3606_Save.o_Busy = FALSE THEN
	SaveOdBlockActions(i_StateForActions := FALSE);
END_IF

(* Check reset request only if there is no data store going on. Exception is if error counter is bigger than 10 *)
IF G_RESET_MODULE AND NvRam_3606_Save.o_Busy = FALSE THEN
	(* Reset control unit *)
	SYSTEM_RESTART_PLCOPEN_APP(0);
END_IF

(* Block actions if voltage level is under defined limit *)
IF G_HWDiagnostics.o_SupplyVoltage > G_LowLimitForParameterSaving THEN

    (* Check if fast parameters are necessary to save *)
    IF G_3606_FastParamsSave = TRUE AND NvRam_3606_Save.o_Busy = FALSE THEN
        G_3606_FastParamsSave := FALSE;
        NvRam_3606_Save(
            i_SaveFastParamsStart:= TRUE,
            i_TimeOutValue:= G_3606_NVRAM_SAVE_MAX_TIME,
            i_SizeOfParams := G_3606_PARAM_SIZE,
            i_SizeOfFastParams := G_3606_FAST_PARAM_SIZE);
    END_IF

    (* If RAM image is changed nvram copying is always started again from begin. *)
    IF G_3606_OldImageChanged <> G_FileSysFileSystem.RamImageChanged AND G_3606_CopyNvRam.o_Busy = FALSE THEN
        SaveOdBlockActions(i_StateForActions := TRUE);
        G_3606_OldImageChanged := G_FileSysFileSystem.RamImageChanged;
        NvRam_3606_Save(
            i_SaveParamsStart:= TRUE,
            i_TimeOutValue:= G_3606_NVRAM_SAVE_MAX_TIME,
            i_SizeOfParams := G_3606_PARAM_SIZE,
            i_SizeOfFastParams := G_3606_FAST_PARAM_SIZE);
    END_IF

    (* Check if it is necessary to save communication parameters *)
    IF G_3606_CommsSaveOldCnt <> G_ODSAVE_SAVE_COMMS_COUNTER THEN
    	SystemParameters.i_CAN1 := OD_G_CAN1_Comms;

        SystemParameters.WriteData();
        G_3606_CommsSaveOldCnt := G_ODSAVE_SAVE_COMMS_COUNTER;
    END_IF

    (* Check if it is necessary to restor communication parameters *)
    IF G_3606_CommsRestoreOldCnt <> G_ODSAVE_RESTORE_COMMS_COUNTER THEN
        (* Restore communication parameters *)
        SystemParameters.RestoreDefaultData();
    	OD_G_CAN1_Comms := SystemParameters.i_CAN1;

        G_3606_CommsRestoreOldCnt := G_ODSAVE_RESTORE_COMMS_COUNTER;
    END_IF

END_IF

(* Overcurrent protection for mA AI inputs *)
AIP_InputProtection_3606(
	o_NoErrors=>G_NoErrors ,
	o_XM1_20_OverCurrent=>G_X1_20_OverCurrent ,
	o_XM1_21_OverCurrent=>G_X1_21_OverCurrent ,
	o_XM1_31_OverCurrent=>G_X1_31_OverCurrent,
	o_XM1_32_OverCurrent=>G_X1_32_OverCurrent );





END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Other_EpecOut TO Init_EpecOut:=
FALSE


END_TRANSITION


END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)

TRANSITION FROM (EPEC_In,Application,EPEC_Out) TO Init:=
FALSE
END_TRANSITION

END_PROGRAM

MACRO
MacroName: 'ImportLibs'
