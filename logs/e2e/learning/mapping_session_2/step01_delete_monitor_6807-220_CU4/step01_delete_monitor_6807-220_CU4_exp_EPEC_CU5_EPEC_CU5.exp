(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '' *)
(* @SYMFILEFLAGS := '2048' *)
PROGRAM PLC_PRG
VAR
(*
		Tool version       : '8.4.9308.1109'
		Xml version        : '5.0.46'
		Control Unit       : 'EPEC_CU5'
		Control Unit Type  : '3724'
		Export Time        : '15.05.2026 11:30.02'
		Export Path        : 'D:\4_AIProject\4_CoDeSys\AI_MutiTool\MultiToolProject\E2EProject\EPEC_CU5'
		Project File       : 'D:\4_AIProject\4_CoDeSys\AI_MutiTool\MultiToolProject\E2EProject\DasDemoProject.mtproject'
		Libraries Path     : 'D:\4_AIProject\4_CoDeSys\AI_MutiTool\MultiToolProject\E2EProject\EPEC_CU5\Libraries'
*)


(* Code template local variables don't remove *)
CANInitSequencer:BYTE := 0;

END_VAR
(* @END_DECLARATION := '0' *)
INITIAL_STEP Init:

INITIAL_STEP Init_Entry:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
	SystemParameters.ReadData();

	OD_G_CAN1_Comms := SystemParameters.i_CAN1;

	G_InitEntryReady:=TRUE;
END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Entry TO Init_Flash:=
G_InitEntryReady
END_TRANSITION
INITIAL_STEP Init_Flash:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
G_InitFlashReady := FALSE;

IF G_3724_NvLoadStarted = FALSE THEN
	NvRam_3724_Init(i_Enable :=TRUE, i_KeyWordFastParams := G_FileSysKeyWord, i_SizeOfParams := G_3724_PARAM_SIZE, i_SizeOfFastParams := G_3724_FAST_PARAM_SIZE);
	G_3724_NvLoadStarted := TRUE;
ELSE
	NvRam_3724_Init();

	(* Flash init ready exit from block *)
	IF NvRam_3724_Init.o_InitDone = TRUE THEN

	  G_3724_ErrFastParamsLoad := NvRam_3724_Init.o_ErrorFastParams;
	  G_3724_ErrParamsLoad := NvRam_3724_Init.o_ErrorParams;

	  FileSysInit(
			  i_FileSysKey:=G_FileSysKeyWord ,
			  i_pStart:= ADR(G_3724_ParameterImage[3]) ,                      (* Image contains footer and header. *)
			  i_pEnd:=  ADR(G_3724_ParameterImage[G_3724_PARAM_SIZE-2]),
			  i_BlockSize:= G_3724_BLOCK_SIZE_FILE_SYS ,
			  o_Error=> G_3724_ErrFileSysInit);
	      G_FileSysDir := G_FileSysFileSystem.Dir;
		   (* Store old ram image changed counter *)
		G_3724_OldImageChanged := G_FileSysFileSystem.RamImageChanged;
		G_InitFlashReady := TRUE;
	END_IF

END_IF

END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Flash TO Init_IO:=
G_InitFlashReady
END_TRANSITION
INITIAL_STEP Init_IO:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
	;
(*IO init:*)
    (* System inits *)
SYSTEM_FW_VERSION:=SystemParameters.o_SoftwareVersion;
SYSTEM_ControlUnitType := SystemParameters.o_ProductCode;
SYSTEM_ControlUnitRevision := SystemParameters.o_RevisionNumber;
SYSTEM_SerialNumber := SystemParameters.o_SerialNumber;
SYSTEM_VendorId := SystemParameters.o_VendorId;

(* Enabled 5V reference as default *)
REF_OUT_5V_Enable := TRUE;
(* Enabled 12V reference as default *)
REF_OUT_12V_Enable := TRUE;

(* Init conversion array for supply voltage measurement *)
    G_AIBufferOf_SupplyVolt.i_CH:= 14;
    G_AIBufferOf_SupplyVolt.i_Data := ADR(AI_ARR_SupplyVolt);
    G_AIBufferOf_SupplyVolt.i_Length := SIZEOF(AI_ARR_SupplyVolt);
    G_AIBufferOf_SupplyVolt();

(* Init conversion array for PCB temperature measurement *)
    G_AIBufferOf_PcbTemperature.i_CH:= 15;
    G_AIBufferOf_PcbTemperature.i_Data := ADR(AI_ARR_PCBTemperature);
    G_AIBufferOf_PcbTemperature.i_Length := SIZEOF(AI_ARR_PCBTemperature);
    G_AIBufferOf_PcbTemperature();

(* Init conversion array 12V reference voltage measurement *)
    G_AIBufferOf_Ref12V.i_CH:= 13;
    G_AIBufferOf_Ref12V.i_Data := ADR(AI_ARR_Ref12V);
    G_AIBufferOf_Ref12V.i_Length := SIZEOF(AI_ARR_Ref12V);
    G_AIBufferOf_Ref12V();

(* Init conversion array 2.5V reference voltage  measurement *)
    G_AIBufferOf_Ref5V.i_CH:= 12;
    G_AIBufferOf_Ref5V.i_Data := ADR(AI_ARR_Ref5V);
    G_AIBufferOf_Ref5V.i_Length := SIZEOF(AI_ARR_Ref5V);
    G_AIBufferOf_Ref5V();


