	G_NoErrors:BOOL := FALSE; (* No active errors for AI overcurrent protection. *)
	G_X1_12_OverCurrent:BOOL := FALSE; (* Error status for AI over current protection *)
	G_X2_12_OverCurrent:BOOL := FALSE; (* Error status for AI over current protection *)
	G_X3_5orX3_6orX3_7_OverCurrent:BOOL := FALSE; (* Error status for AI over current protection *)
