	G_X3_13orX3_14_OverCurrent:BOOL := FALSE; (* Error status for AI over current protection *)
	REF_OUT_5V_OVERLOAD AT %IX6.3:BOOL := FALSE; (* Overload status for 5 V reference output (TRUE - Fault active). *)
	AUX_OUT_StatusOK AT %IX7.2:BOOL := FALSE; (* Status for auxilary output (TRUE - Auxilary output OK.) *)
