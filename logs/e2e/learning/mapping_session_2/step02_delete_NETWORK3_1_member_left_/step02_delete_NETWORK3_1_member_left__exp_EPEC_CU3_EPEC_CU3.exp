	AI_SupplyLogic:WORD := 0; (* Filtered supply logic raw value (10 sample mean). *)
	SUPPLY_Logic:WORD := 0; (* Logic voltage [10 mV]. *)
	POWER_1_Enable:BOOL := FALSE; (* Disable/Enable power switch 1. *)
	AI_SupplyPower1:WORD := 0; (* Filtered Power switch 1 voltage raw value (10 sample mean). *)
	SUPPLY_Power1:WORD := 0; (* Power switch 1 voltage [10 mV]. *)
	POWER_2_Enable:BOOL := FALSE; (* Disable/Enable power switch 2. *)
	AI_SupplyPower2:WORD := 0; (* Filtered Power switch 2 voltage raw value (10 sample mean). *)
	SUPPLY_Power2:WORD := 0; (* Power switch 2 voltage [10 mV]. *)
	REF_OUT_5V_Enable AT %QX1412.6:BOOL := FALSE; (* Enable for 5 V reference. *)
	AI_Ref5V:WORD := 0; (* Filtered Ref 5 V voltage raw value (10 sample mean). *)
	REF_5V:WORD := 0; (* Scaled Ref 5 V voltage  [10 mV]. *)
	REF_OUT_10V_Enable AT %QX1412.5:BOOL := FALSE; (* Enable for 10 V reference. *)
	AI_Ref10V:WORD := 0; (* Filtered Ref 10 V voltage raw value (10 sample mean). *)
	REF_10V:WORD := 0; (* Scaled Ref 10 V voltage [10 mV]. *)
	AI_10VPullUpSupply:WORD := 0; (* Filtered 10 V Pull-ups voltage raw value (10 sample mean). *)
	REF_10VPullUpSupply:WORD := 0; (* Scaled 10 V Pull-ups voltage [10 mV]. *)
	AI_InternADCReference:WORD := 0; (* Filtered ADC reference. raw value (10 sample mean). *)
	REF_InternADC:WORD := 0; (* ADC reference voltage [10 mV]. *)
	AI_PCBTemperature:WORD := 0; (* Filtered PCB temperature raw value (10 sample mean). *)
	TEMP_PCB:INT := 0; (* PCB temperature [0.1 C]. *)
	AI_CoreTemperature:WORD := 0; (* Filtered core temperature raw value (10 sample mean). *)
	TEMP_CoreTemperature:INT := 0; (* Core temperature [0.1 C]. *)
	AI_Power1Pin:WORD := 0; (* Filtered pin 2.24 / 2.25 input voltage value. *)
	SUPPLY_Power1Pin:WORD := 0; (* Scaled pin 2.24 / 2.25 input voltage value [0.01 V] *)
	AI_Power2Pin:WORD := 0; (* Filtered pin 3.24 / 3.25 input voltage value. *)
	SUPPLY_Power2Pin:WORD := 0; (* Scaled pin 3.24 / 3.25 input voltage value [0.01 V] *)
END_VAR
