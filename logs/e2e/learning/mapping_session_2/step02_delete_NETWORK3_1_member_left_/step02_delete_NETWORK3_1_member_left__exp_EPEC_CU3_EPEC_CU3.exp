	AI_ARR_Ref5V AT %IW2876:ARRAY [1..50] OF WORD; (* Array of  measured raw values for Ref 5 V voltage. *)
	AI_RAW_Ref10V AT %IW2072:WORD := 0; (* Latest measured raw value for Ref 10 V voltage. *)
	AI_ARR_Ref10V AT %IW2976:ARRAY [1..50] OF WORD; (* Array of  measured raw values for Ref 10 V voltage. *)
