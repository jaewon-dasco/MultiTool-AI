

(* @NESTEDCOMMENTS := 'Yes' *)
(* @GLOBAL_VARIABLE_LIST := 'Code_Template_globals' *)
(* @PATH := 'Implicit Globals' *)
(* @SYMFILEFLAGS := '2048' *)
VAR_GLOBAL CONSTANT
	G_MAX_NUMBER_OF_COBIDS:DWORD:=100;
	G_CANOPEN_NUMBER_OF_LAST_PDO_MAP:WORD:=8;
	G_CANOPEN_OD_SAVE_MAX_IND_SIZE:WORD:=1020;
	G_MRAM_AREA_SIZE_FOR_PAR_SYS:DWORD := 16#19000;	(* Size for the area which is used for parameter system. This area is reserved from the beginning of the MRAM area which is reserved for usage for PLCopn application. *)
END_VAR

VAR_GLOBAL
(*START - Implicit variables, made by EPEC Parser*)
	G_HWDiagnostics:HWD_Measurements; (* Function block for HWD_Measurements. *)
	G_RESET_MODULE:BOOL := FALSE; (* Flag indicates if unit is wanted to reset after current application cycle. Reset actions can be varied between platforms. *)
	G_AddAllAutoGenEventsToLog:BOOL := TRUE; (* Add all automatically generated events to log. *)
	G_OffDelayForAutoGenEvents:WORD := 50; (* Off delay for automatically generated events. *)
	G_OnDelayForAutoGenEvents:WORD := 100; (* On delay for automatically generated events. *)
	G_LowLimitForParameterSaving:WORD := 900; (* Variable defines low limit for parameter saving [0.01V]. Compared votlage is read from HWD_Measurements function block. If read voltage is smaller than defined value parameter saving is not started. *)
	G_SystemOk:BOOL:=FALSE;
	G_TempHighLimit:INT:=1050;
	G_TempLowLimit:INT:=-400;
	G_SupplyVoltageHighLimit:INT:=3600;
	G_SupplyVoltageLowLimit:INT:=900;
	G_CycleTimeHighLimit:INT:=30;
	G_Ref5VHighLimit:INT:=550;
	G_Ref5VLowLimit:INT:=450;
	G_Ref10VHighLimit:INT:=1050;
	G_Ref10VLowLimit:INT:=950;
	G_PullUp10VHighLimit:INT:=1050;
	G_PullUp10VLowLimit:INT:=950;
	G_RefADCVHighLimit:INT:=150;
	G_RefADCVLowLimit:INT:=100;

(*Init Flags*)
	G_InitEntryReady:BOOL:=FALSE;
	G_InitFlashReady:BOOL:=FALSE;
	G_InitIOReady:BOOL:=FALSE;
	G_InitBusReady:BOOL:=FALSE;
	G_InitProtocolsCan1Ready:BOOL:=FALSE;
	G_InitProtocolsCan2Ready:BOOL:=FALSE;
	G_InitProtocolsCan3Ready:BOOL:=FALSE;
	G_InitProtocolsCan4Ready:BOOL:=FALSE;
	G_InitIsobusCan1Ready:BOOL:=FALSE;
	G_InitIsobusCan2Ready:BOOL:=FALSE;
	G_InitIsobusCan3Ready:BOOL:=FALSE;
	G_InitIsobusCan4Ready:BOOL:=FALSE;
	G_InitEventsReady:BOOL:=FALSE;
	G_InitExitReady:BOOL:=FALSE;
	G_ActiveError:BOOL:=FALSE;


  	G_CounterRestoreCmdOld:WORD := 0;
	G_CounterSaveCmdOld:WORD := 0;

	G_ShmUserMRAM:SystemSharedMemRegion;      (* MRAM area used by File system. *)
	G_FileSysDir:POINTER TO FileSysDirBlock;  (* Pointer to file system block which contains dir. *)
	G_FileSysKeyWord:DWORD:=16#6D27A7B0;      (* Keyword which is used to check match between file system and Codesys project. *)

(*
	Pointer G_MramStartAddressForUser and G_MramEndAddressForUser are used to tell user MRAM area which can be freely used.
	SYSTEM_SHM_MRAM_GET_IEC_AREA return area which is used for PLCopen application. However multitool creates parameter
	system when it creates Codesys project and this parameter system uses certain amount of this whole MRAM area. Size of
	the area is defined with global constant G_MRAM_AREA_SIZE_FOR_PAR_SYS:DWORD:= 16#19000.
*)
	G_MramInitErrors:INT:=0;										(* Tells possible errors in MRAM init. 0 - success, 1 - Error in block  *)
	G_MramStartAddressForUser:POINTER TO BYTE;	(* Start address for user MRAM area (=MRAM start + G_MRAM_AREA_SIZE_FOR_PAR_SYS *)
	G_MramEndAddressForUser:POINTER TO BYTE;	(* End address for user MRAM area (=End of the MRAM *)


(*Error codes*)
	G_FlashInitError:INT;
	G_SetIdentityError:INT:=0;
	G_ReadCommsError:INT:=0;
	G_RS232InitError:INT:=0;

(* Global NodeIds *)
	G_NodeIds:ARRAY[1..4] OF INT := 3, 3, 3, 3;


	G_CAN1_CANopenDevice: CANopenDev;
	G_CAN1_CANopenDevice_OD: CANopenOD;(*Description of ObjectDictionary*)
	G_CAN1_CANopenDevice_ODEntrys: ARRAY [1..71] OF CANopenOD_ENTRY;(*ObjectDictionary data*)
	G_CAN1_CANopenDevice_Protocols:ARRAY [1..5] OF CANopenProtocolEntry;(*Used protocols - NMT, OD, SSDO, SYNC & HBCons always exist*)
	G_CAN1_CANopenDevice_NMT: CANopenNMT;
	G_CAN1_CANopenDevice_SSDO: CANopenSSDO;
	G_CAN1_CANopenDevice_SYNC: CANopenSYNC  := (COBID := 16#80);
	G_CAN1_CANopenDevice_HBConsumer:CANopenHeartBeatConsumer; (*HeartBeat Consumer protocol*)
	G_CAN1_CANopenDevice_SaveData:ARRAY [0..3] OF sSaveIndexData :=
					(StartIndex:=16#1000, EndIndex:=16#FFFF, FileName:='Device1.Par'),
					(StartIndex:=16#1000, EndIndex:=16#1FFF, FileName:='Device1.Par'),
					(StartIndex:=16#2000, EndIndex:=16#FFFF, FileName:='Device1.Par'),
					(StartIndex:=16#0000, EndIndex:=16#0000, FileName:='Device1.Par');
	G_CAN1_CANopenDevice_SaveSubData1010h:sODSave:= (SubService:=Save,Sub1Count:=0,pNext:=0,NumOfEntrys:=4,SaveIndexData:=0,SaveSigns:=0,NextOD:=0);
	G_CAN1_CANopenDevice_SaveSigns1010:ARRAY [0..3] OF DWORD;


(*Init diagnostics CAN1*)
	G_CAN1_Diagnostics:CANVXDDiagnostic;
(*Init monitoring CAN1*)
	G_CAN1_NetworkManager:NM_NetworkManager;
	G_CAN1_MonitoredNodes:ARRAY [1..1] OF NM_Node:=
		( NodeID:=1, ConsumerTime:=400, KeepAlive:=FALSE, Reset:=FALSE, Mandatory:=TRUE );

	G_CAN1_CANopenDevice_HbConsumerNodes:ARRAY [1..1] OF CANopenHeartBeat:=
		(i_NodeID:=1,i_Time:=T#400ms,i_Next:=0);

	G_CAN1_CSDOinstances:ARRAY [1..127] OF CANopenCSDO:=
		(i_NodeID:=1,i_Enable:=FALSE,i_Channel:=0);
(*Init diagnostics CAN2*)
	G_CAN2_Diagnostics:CANVXDDiagnostic;
(*Init diagnostics CAN3*)
	G_CAN3_Diagnostics:CANVXDDiagnostic;
(*Init diagnostics CAN4*)
	G_CAN4_Diagnostics:CANVXDDiagnostic;




(*END - Implicit variables, made by EPEC Parser*)
END_VAR
(* @OBJECT_END := 'Code_Template_globals' *)
(* @CONNECTIONS :=Code_Template_globals
FILENAME:  ''
FILETIME : 0
EXPORT : 0
NUMOFCONNECTIONS : 0
*)



