(* @PATH := '' *)
(* @SYMFILEFLAGS := '2048' *)
PROGRAM PLC_PRG
VAR
(*
		Tool version       : '8.4.9308.1109'
		Xml version        : '5.0.45'
		Control Unit       : 'EPEC_CU3'
		Control Unit Type  : '5050'
		Export Time        : '15.05.2026 11:38.33'
		Export Path        : 'D:\4_AIProject\4_CoDeSys\AI_MutiTool\MultiToolProject\E2EProject\EPEC_CU3'
		Project File       : 'D:\4_AIProject\4_CoDeSys\AI_MutiTool\MultiToolProject\E2EProject\DasDemoProject.mtproject'
		Libraries Path     : 'D:\4_AIProject\4_CoDeSys\AI_MutiTool\MultiToolProject\E2EProject\EPEC_CU3\Libraries'
*)


(* Code template local variables don't remove *)
CANInitSequencer:BYTE := 0;

END_VAR
(* @END_DECLARATION := '0' *)
INITIAL_STEP Init:

INITIAL_STEP Init_Entry:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
	SystemParameters.ReadData();

	OD_MACAddress := SystemParameters.o_MAC;
	OD_EthernetConfiguration := SystemParameters.i_Ethernet;
	OD_CAN1Config := SystemParameters.i_CAN1;


	IO_SET_LED(i_SystemOk:=0, i_RunWithErrors:=0, i_InitState:=1);
	G_InitEntryReady:=TRUE;
END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Entry TO Init_Flash:=
G_InitEntryReady
END_TRANSITION
INITIAL_STEP Init_Flash:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)

  	(* Get info for MRAM area used for programmer. *)
  	SYSTEM_SHM_MRAM_GET_IEC_AREA(ADR(G_ShmUserMRAM));
  	(* Check addresses and divide area between parameter system and are available for user *)
	IF ((G_ShmUserMRAM.endAddress > 0) AND (G_ShmUserMRAM.startAddress > 0))
		AND (G_ShmUserMRAM.endAddress > (G_ShmUserMRAM.startAddress + G_MRAM_AREA_SIZE_FOR_PAR_SYS + 100)) THEN
		(* Init file system for parameters *)
		FileSysInit(	i_FileSysKey:= G_FileSysKeyword,
			i_pStart:= G_ShmUserMRAM.startAddress,
			i_pEnd:= G_ShmUserMRAM.startAddress + G_MRAM_AREA_SIZE_FOR_PAR_SYS - 1,
			i_BlockSize:= 1024);
		G_FileSysDir:=G_ShmUserMRAM.startAddress + 1024;
		(* Set user MRAM pointers, which tells area for freely used by programmer. *)
		G_MramStartAddressForUser := G_ShmUserMRAM.startAddress + G_MRAM_AREA_SIZE_FOR_PAR_SYS;
		G_MramEndAddressForUser := G_ShmUserMRAM.endAddress ;
	ELSE
		(* Error *)
		G_MramInitErrors := - 1;
	END_IF

  G_InitFlashReady:=TRUE;
END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Flash TO Init_IO:=
G_InitFlashReady
END_TRANSITION
