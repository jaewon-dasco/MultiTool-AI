END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
STEP Diag:
;
(* Update functionalities for IO*)
	(* HW diagnostic *)
	AI_SupplyLogic := AI_MeanValue(AI_ARR_INDEX,ADR(AI_ARR_SupplyLogic[1]),1,50, 10); (* Filter logic supply raw values*)
	AI_Ref5V := AI_MeanValue(AI_ARR_INDEX,ADR(AI_ARR_Ref5V[1]),1,50, 10); (* Filter 5V ref raw values. *)
	AI_Ref10V := AI_MeanValue(AI_ARR_INDEX,ADR(AI_ARR_Ref10V[1]),1,50, 10); (* Filter 10V ref raw values. *)
	AI_PCBTemperature := AI_MeanValue(AI_ARR_INDEX,ADR(AI_ARR_PCBTemperature[1]), 1,50, 10);
	AI_SupplyPower1 := AI_MeanValue(AI_ARR_INDEX,ADR(AI_ARR_SupplyPower1[1]), 1,50, 10); (* Filter power switch 1 raw values*)
	AI_SupplyPower2 := AI_MeanValue(AI_ARR_INDEX,ADR(AI_ARR_SupplyPower2[1]), 1,50, 10); (* Filter power switch 2 raw values*)
	AI_10VPullUpSupply := AI_MeanValue(AI_ARR_INDEX,ADR(AI_ARR_10VPullUpSupply[1]),1,50, 10);
	AI_InternADCReference := AI_MeanValue(AI_ARR_INDEX,ADR(AI_ARR_InternADCReference[1]), 1,50, 10);
	AI_CoreTemperature := AI_MeanValue(AI_ARR_INDEX,ADR(AI_ARR_CoreTemperature[1]), 1,50, 10);
	AI_Power1Pin := AI_MeanValue(AI_ARR_INDEX,ADR(AI_ARR_Power1Pin[1]), 1,50, 10);
	AI_Power2Pin := AI_MeanValue(AI_ARR_INDEX,ADR(AI_ARR_Power2Pin[1]), 1,50, 10);

	G_HWDiagnostics(
		i_SupplyVoltage1:=AI_SupplyLogic,
		i_SupplyVoltage2:=AI_Power1Pin ,
		i_SupplyVoltage3:=AI_Power2Pin,
		i_Ref5V:=AI_Ref5V,
		i_Ref10V:=AI_Ref10V,
		i_Pullup10V := AI_10VPullUpSupply,
		i_RefADC := AI_InternADCReference,
		i_Temperature1 := AI_CoreTemperature,
		i_Temperature2 := AI_PCBTemperature,
		i_SupplyVoltageHighLimit := G_SupplyVoltageHighLimit,
		i_SupplyVoltageLowLimit := G_SupplyVoltageLowLimit,
		i_Ref5VHighLimit := G_Ref5VHighLimit,
		i_Ref5VLowLimit := G_Ref5VLowLimit,
		i_Ref10VHighLimit := G_Ref10VHighLimit,
		i_Ref10VLowLimit := G_Ref10VLowLimit,
		i_PullUp10VHighLimit := G_PullUp10VHighLimit,
		i_PullUp10VLowLimit := G_PullUp10VLowLimit,
		i_RefADCVHighLimit := G_RefADCVHighLimit,
		i_RefADCVLowLimit := G_RefADCVLowLimit,
		i_TempHighLimit := G_TempHighLimit,
		i_TempLowLimit := G_TempLowLimit,
		i_CycleTimeHighLimit := G_CycleTimeHighLimit);

		SUPPLY_Logic := G_HWDiagnostics.o_SupplyVoltage1;
		SUPPLY_Power1Pin:= G_HWDiagnostics.o_SupplyVoltage2;
		SUPPLY_Power2Pin := G_HWDiagnostics.o_SupplyVoltage3;
		REF_10V := G_HWDiagnostics.o_Ref10V;
		REF_5V := G_HWDiagnostics.o_Ref5V;
		REF_10VPullUpSupply := G_HWDiagnostics.o_PullUp10V;
		REF_InternADC := G_HWDiagnostics.o_RefADCV;
		TEMP_PCB := G_HWDiagnostics.o_Temperature2;
		TEMP_CoreTemperature := G_HWDiagnostics.o_Temperature1;

		SUPPLY_Power1 := ADC_To_mAorV(AI_SupplyPower1,G_AIType.Supply);
		SUPPLY_Power2 := ADC_To_mAorV(AI_SupplyPower2,G_AIType.Supply);


	(* Update power switches and scale voltages measurement *)
		SYSTEM_PWR_SWT_SET_STATE(0,BOOL_TO_BYTE(POWER_1_Enable));
	(* Update power switches *)
		SYSTEM_PWR_SWT_SET_STATE(1,BOOL_TO_BYTE(POWER_2_Enable));









(*########################################################*)
(*This block is created implicit. Don't add own code here.*)
(*########################################################*)

(* Diagnostics for CAN interfaces *)
G_CAN1_Diagnostics(i_DrvNbr:=0);
G_CAN2_Diagnostics(i_DrvNbr:=1);
G_CAN3_Diagnostics(i_DrvNbr:=2);
G_CAN4_Diagnostics(i_DrvNbr:=3);

(* CANopen networks management and diagnostics  *)
G_CAN1_NetworkManager();




(* System Ok conditions *)
G_SystemOk:=NOT(G_HWDiagnostics.o_Temperature1High) AND
		NOT(G_HWDiagnostics.o_Temperature1Low) AND
		NOT(G_HWDiagnostics.o_Temperature2High) AND
		NOT(G_HWDiagnostics.o_Temperature2Low) AND
		NOT(G_HWDiagnostics.o_SupplyVoltage1High) AND
		NOT(G_HWDiagnostics.o_SupplyVoltage1Low) AND
		NOT(G_HWDiagnostics.o_PullUp10VHigh) AND
		NOT(G_HWDiagnostics.o_PullUp10VLow) AND
		NOT(G_HWDiagnostics.o_RefADCVHigh) AND
		NOT(G_HWDiagnostics.o_RefADCVLow) AND
		NOT (ERR_FLAG_IO_INIT);



POWER_1_Enable:=G_SystemOk;
POWER_2_Enable:=G_SystemOk;



IO_SET_LED(i_SystemOk:=G_SystemOk, i_RunWithErrors:=G_ActiveError, i_InitState:=NOT(G_InitExitReady));


IF G_HWDiagnostics.o_SupplyVoltage1 > G_LowLimitForParameterSaving THEN
	SaveODBlockActions(FALSE);
ELSE
	SaveODBlockActions(TRUE);
END_IF

END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
STEP Bus:
;


	CANVXDCheckMessages();(*Receive CAN-data*)
	CANopenUpdateDevices();(*Updates data of protocols in devices and send CAN-data*)

	(*Check for nmt reset *)
	IF G_CAN1_CANopenDevice_NMT.StateChanged THEN
		IF G_CAN1_CANopenDevice_NMT.LastNmtCommand = 16#81 OR G_CAN1_CANopenDevice_NMT.LastNmtCommand = 16#82 THEN
			(* If there is NMT reset command for IEC application CANopen device,
				IEC application is started after IEC cycle in execution. *)
					G_RESET_MODULE := TRUE;
		END_IF
	END_IF




END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
STEP Other:
;




END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM (IOFilter,Diag,Bus,Other) TO Init_EpecIn:=
FALSE


END_TRANSITION


END_STEP

STEP Application:
INITIAL_STEP Init_Application:
END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Application TO Main_Application:=
TRUE
END_TRANSITION

STEP Main_Application:
(* Call user application *)
    Main();
END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Main_Application TO Init_Application:=
FALSE
END_TRANSITION
END_STEP

STEP Epec_Out:

INITIAL_STEP Init_EpecOut:


END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_EpecOut TO Other_EpecOut:=
TRUE


END_TRANSITION
STEP Other_EpecOut:
(* tag EPEC_OUT_OTHER *)

(* If reset flag is on make reset. For 5050 PLCopen application is reseted. *)
IF G_RESET_MODULE THEN
    SYSTEM_RESTART_PLCOPEN_APP(0);
END_IF

(* Block actions if voltage level is under defined limit *)
IF G_HWDiagnostics.o_SupplyVoltage1 > G_LowLimitForParameterSaving THEN

    IF	G_CounterRestoreCmdOld <> G_ODSAVE_RESTORE_COMMS_COUNTER THEN
        (* Restore command given trough CANopen *)
        G_CounterRestoreCmdOld := G_ODSAVE_RESTORE_COMMS_COUNTER;
        SystemParameters.RestoreDefaultData();
    	OD_MACAddress := SystemParameters.o_MAC;
	OD_EthernetConfiguration := SystemParameters.i_Ethernet;
	OD_CAN1Config := SystemParameters.i_CAN1;

    END_IF

    IF G_CounterSaveCmdOld <> G_ODSAVE_SAVE_COMMS_COUNTER THEN
        (* Save command given trough CANopen *)
        G_CounterSaveCmdOld := G_ODSAVE_SAVE_COMMS_COUNTER;

    	SystemParameters.i_Ethernet := OD_EthernetConfiguration;
	SystemParameters.i_CAN1 := OD_CAN1Config;

        SystemParameters.WriteData();
    END_IF

    

END_IF





END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Other_EpecOut TO Init_EpecOut:=
FALSE


END_TRANSITION


END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)

TRANSITION FROM (EPEC_In,Application,EPEC_Out) TO Init:=
FALSE
END_TRANSITION

END_PROGRAM

MACRO
MacroName: 'ImportLibs'
MacroMenu: 'Import Libraries'
MacroCmd: 'library delete J1939.lib 5050CANVXD.lib 5050ext.lib 5050int.lib 5050specific.lib ADConversion.lib AddressClaiming.lib AI.lib CANopen.lib CANopenCSDO.lib CANopenODSave.lib CANopen_302.lib DataTransfer.lib DigitalOutputDiagnostic.lib EventLog.lib EventLogTransfer.lib FileSys.lib Filters.lib J1939Event.lib JoystickCalibrationAndDiagnostic.lib NetworkManager.lib Ramp.lib ProportionalValveControl.lib SensorCalibrationAndDiagnostic.lib Standard.lib SysLibMem.lib SysLibProjectInfo.lib SysLibRtc.lib Util.lib'
MacroCmd: 'library add J1939.lib 5050CANVXD.lib 5050ext.lib 5050int.lib 5050specific.lib ADConversion.lib AddressClaiming.lib AI.lib CANopen.lib CANopenCSDO.lib CANopenODSave.lib CANopen_302.lib DataTransfer.lib DigitalOutputDiagnostic.lib EventLog.lib EventLogTransfer.lib FileSys.lib Filters.lib J1939Event.lib JoystickCalibrationAndDiagnostic.lib NetworkManager.lib Ramp.lib ProportionalValveControl.lib SensorCalibrationAndDiagnostic.lib Standard.lib SysLibMem.lib SysLibProjectInfo.lib SysLibRtc.lib Util.lib'
END_MACRO


    
MACRO
MacroName: 'ImportMultiTool'
MacroMenu: 'Import MultiTool'
MacroCmd: 'file save'
MacroCmd: 'project import EPEC_CU3.exp' ;Import exp - file generated by MultiTool
MacroCmd: 'call ImportLibs'
MacroCmd: 'project clean'
END_MACRO

