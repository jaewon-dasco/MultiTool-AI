(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_EpecOut TO Other_EpecOut:=
TRUE


END_TRANSITION
STEP Other_EpecOut:


NvRam_3720_Save();

IF NvRam_3720_Save.o_Busy = FALSE THEN
	SaveOdBlockActions(i_StateForActions := FALSE);
END_IF

(* Check reset request only if there is no data store going on. Exception is if error counter is bigger than 10 *)
IF G_RESET_MODULE AND NvRam_3720_Save.o_Busy = FALSE THEN
	(* Reset control unit *)
	SYSTEM_RESTART_PLCOPEN_APP(0);
END_IF

(* Block actions if voltage level is under defined limit *)
IF G_HWDiagnostics.o_SupplyVoltage > G_LowLimitForParameterSaving THEN

    (* Check if fast parameters are necessary to save *)
    IF G_3720_FastParamsSave = TRUE AND NvRam_3720_Save.o_Busy = FALSE THEN
        G_3720_FastParamsSave := FALSE;
        NvRam_3720_Save(
            i_SaveFastParamsStart:= TRUE,
            i_TimeOutValue:= G_3720_NVRAM_SAVE_MAX_TIME,
            i_SizeOfParams := G_3720_PARAM_SIZE,
            i_SizeOfFastParams := G_3720_FAST_PARAM_SIZE);
    END_IF

    (* If RAM image is changed nvram copying is always started again from begin. *)
    IF G_3720_OldImageChanged <> G_FileSysFileSystem.RamImageChanged AND G_3720_CopyNvRam.o_Busy = FALSE THEN
        SaveOdBlockActions(i_StateForActions := TRUE);
        G_3720_OldImageChanged := G_FileSysFileSystem.RamImageChanged;
        NvRam_3720_Save(
            i_SaveParamsStart:= TRUE,
            i_TimeOutValue:= G_3720_NVRAM_SAVE_MAX_TIME,
            i_SizeOfParams := G_3720_PARAM_SIZE,
            i_SizeOfFastParams := G_3720_FAST_PARAM_SIZE);
    END_IF

    (* Check if it is necessary to save communication parameters *)
    IF G_3720_CommsSaveOldCnt <> G_ODSAVE_SAVE_COMMS_COUNTER THEN
    	SystemParameters.i_CAN1 := OD_G_CAN1_Comms;

        SystemParameters.WriteData();
        G_3720_CommsSaveOldCnt := G_ODSAVE_SAVE_COMMS_COUNTER;
    END_IF

    (* Check if it is necessary to restor communication parameters *)
    IF G_3720_CommsRestoreOldCnt <> G_ODSAVE_RESTORE_COMMS_COUNTER THEN
        (* Restore communication parameters *)
        SystemParameters.RestoreDefaultData();
    	OD_G_CAN1_Comms := SystemParameters.i_CAN1;

        G_3720_CommsRestoreOldCnt := G_ODSAVE_RESTORE_COMMS_COUNTER;
    END_IF

END_IF

(* Overcurrent protection for mA AI inputs *)

AIP_InputProtection_3720(
	o_NoErrors				=> G_NoErrors,
	o_X3_3_OverCurrent 		=>	G_X3_3_OverCurrent,
	o_X3_4_OverCurrent		=>  G_X3_4_OverCurrent,
	o_X3_5_OverCurrent	    =>  G_X3_5_OverCurrent,
	o_X3_6_OverCurrent		=>	G_X3_6_OverCurrent,
	o_X3_7_OverCurrent		=>  G_X3_7_OverCurrent,
    o_X3_8_OverCurrent      =>  G_X3_8_OverCurrent);





END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Other_EpecOut TO Init_EpecOut:=
FALSE


END_TRANSITION


END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)

TRANSITION FROM (EPEC_In,Application,EPEC_Out) TO Init:=
FALSE
END_TRANSITION

END_PROGRAM

