STEP Diag:

(* Mean filtering for supply voltage measurement *)
    AI_ARR_INDEX_SupplyVolt:= WORD_TO_BYTE(G_AIBufferOf_SupplyVolt.o_Write);
    AI_SupplyVolt:=AI_MeanValue(
                i_LatestBufferIndex := AI_ARR_INDEX_SupplyVolt,
                i_pBuffer := G_AIBufferOf_SupplyVolt.i_Data,
                i_FirstIndex := 0,
                i_SizeOfBuffer := 50,
                i_Samples := 10);

(* Mean filtering for PCB temperature measurement *)
    AI_ARR_INDEX_PCBTemperature:= WORD_TO_BYTE(G_AIBufferOf_PcbTemperature.o_Write);
    AI_PCBTemperature:=AI_MeanValue(
                i_LatestBufferIndex := AI_ARR_INDEX_PCBTemperature,
                i_pBuffer := G_AIBufferOf_PcbTemperature.i_Data,
                i_FirstIndex := 0,
                i_SizeOfBuffer := 50,
                i_Samples := 10);

(* Mean filtering for 5V reference measurement *)
    AI_ARR_INDEX_5V_REF:= WORD_TO_BYTE(G_AIBufferOf_5V_REf.o_Write);
    AI_5V_REF:=AI_MeanValue(
                i_LatestBufferIndex := AI_ARR_INDEX_5V_REF,
                i_pBuffer := G_AIBufferOf_5V_REf.i_Data,
                i_FirstIndex := 0,
                i_SizeOfBuffer := 50,
                i_Samples := 10);

(* Mean filtering for 2.5V reference measurement *)
    AI_ARR_INDEX_2_5V_REf:= WORD_TO_BYTE(G_AIBufferOf_2_5V_REF.o_Write);
    AI_2_5V_REF:=AI_MeanValue(
                i_LatestBufferIndex := AI_ARR_INDEX_2_5V_REf,
                i_pBuffer := G_AIBufferOf_2_5V_REF.i_Data,
                i_FirstIndex := 0,
                i_SizeOfBuffer := 50,
                i_Samples := 10);

(* Mean filtering for AI bias measurement *)
    AI_ARR_INDEX_AI_Bias:= WORD_TO_BYTE(G_AIBufferOf_AI_Biaserature.o_Write);
    AI_AI_Bias:=AI_MeanValue(
                i_LatestBufferIndex := AI_ARR_INDEX_AI_Bias,
                i_pBuffer := G_AIBufferOf_AI_Biaserature.i_Data,
                i_FirstIndex := 0,
                i_SizeOfBuffer := 50,
                i_Samples := 10);

(* Mean filtering for PI bias measurement *)
    AI_ARR_INDEX_PI_Bias:= WORD_TO_BYTE(G_AIBufferOf_PI_BiaS.o_Write);
    AI_PI_Bias:=AI_MeanValue(
                i_LatestBufferIndex := AI_ARR_INDEX_PI_Bias,
                i_pBuffer := G_AIBufferOf_PI_BiaS.i_Data,
                i_FirstIndex := 0,
                i_SizeOfBuffer := 50,
                i_Samples := 10);

(* Diagnostic *)
G_HWDiagnostics(
    i_SupplyVoltage := AI_SupplyVolt,
    i_Ref5V := AI_5V_REF,
    i_Ref2V5 := AI_2_5V_REF,
    i_Ref4V3 := AI_PI_Bias,
    i_Ref7V3 := AI_AI_Bias,
    i_Temperature := AI_PCBTemperature,
	i_SupplyVoltageHighLimit:=G_SupplyVoltageHighLimit,
	i_SupplyVoltageLowLimit:=G_SupplyVoltageLowLimit,
	i_Ref5VHighLimit:=G_Ref5VHighLimit,
	i_Ref5VLowLimit:=G_Ref5VLowLimit,
	i_Ref2V5HighLimit:=G_Ref2V5HighLimit,
	i_Ref2V5LowLimit:=G_Ref2V5LowLimit,
	i_Ref4V3HighLimit:=G_RefPiBiasHighLimit,
	i_Ref4V3LowLimit:=G_RefPiBiasLowLimit,
	i_Ref7V3HighLimit:=G_RefAiBiasHighLimit,
	i_Ref7V3LowLimit:=G_RefAiBiasLowLimit,
	i_TempHighLimit:=G_TempHighLimit,
	i_TempLowLimit:=G_TempLowLimit,
	i_CycleTimeHighLimit:=G_CycleTimeHighLimit);

    TEMP_PCB := G_HWDiagnostics.o_Temperature;
    SUPPLY_Volt := G_HWDiagnostics.o_SupplyVoltage;
    REF_5V := G_HWDiagnostics.o_Ref5V;
    REF_2_5V := G_HWDiagnostics.o_Ref2V5;
    PI_BIAS := G_HWDiagnostics.o_Ref4V3;
    AI_BIAS := G_HWDiagnostics.o_Ref7V3;









(*########################################################*)
(*This block is created implicit. Don't add own code here.*)
(*########################################################*)

(* Diagnostics for CAN interfaces *)
G_CAN1_Diagnostics(i_DrvNbr:=0);
G_CAN2_Diagnostics(i_DrvNbr:=1);

(* CANopen networks management and diagnostics  *)
G_CAN1_NetworkManager();


(* System Ok conditions *)
G_SystemOk:=NOT(G_HWDiagnostics.o_TemperatureHigh) AND
		NOT(G_HWDiagnostics.o_TemperatureLow) AND
		NOT(G_HWDiagnostics.o_SupplyVoltageHigh) AND
		NOT(G_HWDiagnostics.o_SupplyVoltageLow) AND
		NOT(G_HWDiagnostics.o_Ref4V3High) AND
		NOT(G_HWDiagnostics.o_Ref4V3Low) AND
		NOT(G_HWDiagnostics.o_Ref7V3High) AND
		NOT(G_HWDiagnostics.o_Ref7V3Low) AND
		NOT(G_HWDiagnostics.o_Ref2V5High) AND
		NOT(G_HWDiagnostics.o_Ref2V5Low) AND
		NOT(G_HWDiagnostics.o_CycleTimeHigh) AND
		NOT (ERR_FLAG_IO_INIT);


END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
STEP Bus:
;


	CANVXDCheckMessages();(*Receive CAN-data*)
	CANopenUpdateDevices();(*Updates data of protocols in devices and send CAN-data*)

	(*Check for nmt reset *)
	IF G_CAN1_CANopenDevice_NMT.StateChanged THEN
		IF G_CAN1_CANopenDevice_NMT.LastNmtCommand = 16#81 OR G_CAN1_CANopenDevice_NMT.LastNmtCommand = 16#82 THEN
			(* If there is NMT reset command for IEC application CANopen device,
				IEC application is started after IEC cycle in execution. *)
					G_RESET_MODULE := TRUE;
		END_IF
	END_IF




END_STEP
