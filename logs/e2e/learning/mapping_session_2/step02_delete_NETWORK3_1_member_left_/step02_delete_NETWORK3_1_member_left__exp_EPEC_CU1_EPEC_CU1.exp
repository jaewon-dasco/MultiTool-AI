(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '' *)
(* @SYMFILEFLAGS := '2048' *)
PROGRAM PLC_PRG
VAR
(*
		Tool version       : '8.4.9308.1109'
		Xml version        : '5.0.47'
		Control Unit       : 'EPEC_CU1'
		Control Unit Type  : '3720'
		Export Time        : '15.05.2026 11:38.33'
		Export Path        : 'D:\4_AIProject\4_CoDeSys\AI_MutiTool\MultiToolProject\E2EProject\EPEC_CU1'
		Project File       : 'D:\4_AIProject\4_CoDeSys\AI_MutiTool\MultiToolProject\E2EProject\DasDemoProject.mtproject'
		Libraries Path     : 'D:\4_AIProject\4_CoDeSys\AI_MutiTool\MultiToolProject\E2EProject\EPEC_CU1\Libraries'
*)

END_VAR
(* @END_DECLARATION := '0' *)
INITIAL_STEP Init:

INITIAL_STEP Init_Entry:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
	SystemParameters.ReadData();

	OD_G_CAN1_Comms := SystemParameters.i_CAN1;

	G_InitEntryReady:=TRUE;
END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Entry TO Init_Flash:=
G_InitEntryReady
END_TRANSITION
INITIAL_STEP Init_Flash:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
G_InitFlashReady := FALSE;

IF G_3720_NvLoadStarted = FALSE THEN
	NvRam_3720_Init(i_Enable :=TRUE, i_KeyWordFastParams := G_FileSysKeyWord, i_SizeOfParams := G_3720_PARAM_SIZE, i_SizeOfFastParams := G_3720_FAST_PARAM_SIZE);
	G_3720_NvLoadStarted := TRUE;
ELSE
	NvRam_3720_Init();

	(* Flash init ready exit from block *)
	IF NvRam_3720_Init.o_InitDone = TRUE THEN

	  G_3720_ErrFastParamsLoad := NvRam_3720_Init.o_ErrorFastParams;
	  G_3720_ErrParamsLoad := NvRam_3720_Init.o_ErrorParams;

	  FileSysInit(
			  i_FileSysKey:=G_FileSysKeyWord ,
			  i_pStart:= ADR(G_3720_ParameterImage[3]) ,                      (* Image contains footer and header. *)
			  i_pEnd:=  ADR(G_3720_ParameterImage[G_3720_PARAM_SIZE-2]),
			  i_BlockSize:= G_3720_BLOCK_SIZE_FILE_SYS ,
			  o_Error=> G_3720_ErrFileSysInit);
	      G_FileSysDir := G_FileSysFileSystem.Dir;
		   (* Store old ram image changed counter *)
		G_3720_OldImageChanged := G_FileSysFileSystem.RamImageChanged;
		G_InitFlashReady := TRUE;
	END_IF

END_IF

END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Flash TO Init_IO:=
G_InitFlashReady
END_TRANSITION
INITIAL_STEP Init_IO:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
	;
(*IO init:*)
    (* System inits *)
SYSTEM_FW_VERSION:=SystemParameters.o_SoftwareVersion;
SYSTEM_ControlUnitType := SystemParameters.o_ProductCode;
SYSTEM_ControlUnitRevision := SystemParameters.o_RevisionNumber;
SYSTEM_SerialNumber := SystemParameters.o_SerialNumber;
SYSTEM_VendorId := SystemParameters.o_VendorId;

(* Init conversion array for supply voltage measurement *)
    G_AIBufferOf_SupplyVolt.i_CH:= 12;
    G_AIBufferOf_SupplyVolt.i_Data := ADR(AI_ARR_SupplyVolt);
    G_AIBufferOf_SupplyVolt.i_Length := SIZEOF(AI_ARR_SupplyVolt);
    G_AIBufferOf_SupplyVolt();

(* Init conversion array for PCB temperature measurement *)
    G_AIBufferOf_PcbTemperature.i_CH:= 10;
    G_AIBufferOf_PcbTemperature.i_Data := ADR(AI_ARR_PCBTemperature);
    G_AIBufferOf_PcbTemperature.i_Length := SIZEOF(AI_ARR_PCBTemperature);
    G_AIBufferOf_PcbTemperature();

 (* Init conversion array for 5V reference *)
    G_AIBufferOf_5V_REf.i_CH:= 11;
    G_AIBufferOf_5V_REf.i_Data := ADR(AI_ARR_5V_REF);
    G_AIBufferOf_5V_REf.i_Length := SIZEOF(AI_ARR_5V_REF);
    G_AIBufferOf_5V_REf();

(* Init conversion array for 2.5V reference *)
    G_AIBufferOf_2_5V_REF.i_CH:= 13;
    G_AIBufferOf_2_5V_REF.i_Data := ADR(AI_ARR_2_5V_REF);
    G_AIBufferOf_2_5V_REF.i_Length := SIZEOF(AI_ARR_2_5V_REF);
    G_AIBufferOf_2_5V_REF();

(* Init conversion array for AI bias *)
    G_AIBufferOf_AI_Biaserature.i_CH:= 14;
    G_AIBufferOf_AI_Biaserature.i_Data := ADR(AI_ARR_AI_Bias);
    G_AIBufferOf_AI_Biaserature.i_Length := SIZEOF(AI_ARR_AI_Bias);
    G_AIBufferOf_AI_Biaserature();

(* Init conversion array for PI bias *)
    G_AIBufferOf_PI_BiaS.i_CH:= 15;
    G_AIBufferOf_PI_BiaS.i_Data := ADR(AI_ARR_PI_Bias);
    G_AIBufferOf_PI_BiaS.i_Length := SIZEOF(AI_ARR_PI_Bias);
    G_AIBufferOf_PI_BiaS();



(* Configurations for pin 1.1 *)

(* Configurations for pin 1.2 *)

(* Configurations for pin 1.7 *)

(* Configurations for pin 1.8 *)

(* Configurations for pin 1.9 *)

(* Configurations for pin 1_11 *)

(* Configurations for pin 1.13 *)

