	G_CANVXD_CAN2_USE_BUFFER:BOOL:=TRUE;

END_VAR

VAR_GLOBAL
(*START - Implicit variables, made by EPEC Parser*)
	G_AIBufferOf_SupplyVolt:IO_SET_AI_BUFFER; (* Function block for AI filtering. *)
	G_AIBufferOf_PcbTemperature:IO_SET_AI_BUFFER; (* Function block for AI filtering. *)
	G_AIBufferOf_5V_REf:IO_SET_AI_BUFFER; (* Function block for AI filtering. *)
	G_AIBufferOf_2_5V_REF:IO_SET_AI_BUFFER; (* Function block for AI filtering. *)
	G_AIBufferOf_AI_Biaserature:IO_SET_AI_BUFFER; (* Function block for AI filtering. *)
	G_AIBufferOf_PI_BiaS:IO_SET_AI_BUFFER; (* Function block for AI filtering. *)
