	;
	

(*CAN2 INIT*)
(* Sequencer is used to split init to smaller steps *)
CASE CANInitSequencer OF
	0: (* Sequencer step 0*)
¤#CAN#1#¤
		CANInitSequencer := CANInitSequencer + 1;
	1: (* Sequencer step 1*)
¤#MONITORING#1#¤
		CANInitSequencer := CANInitSequencer + 1;
	2: (* Sequencer step 2*)
¤#BASEOD#1#¤
		CANInitSequencer := CANInitSequencer + 1;
	3:  (* Sequencer step 3*)
¤#PDO#1#¤
		CANInitSequencer := CANInitSequencer + 1;
	4:   (* Sequencer step 4*)
¤#J9139_INIT_PROTOCOL#1#¤
		CANInitSequencer := CANInitSequencer + 1;
	5:   (* Sequencer step 5*)
¤#AFTER_CAN_INIT#1#¤	
		CANInitSequencer := CANInitSequencer + 1;
	ELSE
		(* Sequencer ready *)
		G_InitProtocolsCan2Ready:=TRUE;
		CANInitSequencer := 0;
END_CASE	

END_STEP

