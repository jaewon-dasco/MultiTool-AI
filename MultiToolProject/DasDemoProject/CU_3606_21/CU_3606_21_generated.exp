(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '' *)
(* @SYMFILEFLAGS := '2048' *)
PROGRAM PLC_PRG
VAR
(*
		Tool version       : '8.4.9308.1109'
		Xml version        : '5.0.45'
		Control Unit       : 'CU_3606_21'
		Control Unit Type  : '3606'
		Export Time        : '22.04.2026 10:10.23'
		Export Path        : 'C:\Users\JONE\Desktop\EPEC\CoDeSysProject\DasDemoProject'
		Project File       : 'C:\Users\JONE\Desktop\EPEC\CoDeSysProject\DasDemoProject\DasDemoProject.mtproject'
		Libraries Path     : 'C:\Users\JONE\Desktop\EPEC\CoDeSysProject\DasDemoProject\Libraries'
*)

(* Code template local variables don't remove *)
CANInitSequencer:BYTE := 0;

END_VAR
(* @END_DECLARATION := '0' *)
INITIAL_STEP Init:

INITIAL_STEP Init_Entry:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
SystemParameters.ReadData();

	OD_G_CAN1_Comms := SystemParameters.i_CAN1;

¤#COMM_CONFIGURATION#0#¤
	G_InitEntryReady:=TRUE;
END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Entry TO Init_Flash:=
G_InitEntryReady
END_TRANSITION
INITIAL_STEP Init_Flash:7
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
G_InitFlashReady := FALSE;

IF G_3606_NvLoadStarted = FALSE THEN
	NvRam_3606_Init(i_Enable :=TRUE, i_KeyWordFastParams := G_FileSysKeyWord, i_SizeOfParams := G_3606_PARAM_SIZE, i_SizeOfFastParams := G_3606_FAST_PARAM_SIZE);
	G_3606_NvLoadStarted := TRUE;
ELSE
	NvRam_3606_Init();

	(* Flash init ready exit from block *)
	IF NvRam_3606_Init.o_InitDone = TRUE THEN

	  G_3606_ErrFastParamsLoad := NvRam_3606_Init.o_ErrorFastParams;
	  G_3606_ErrParamsLoad := NvRam_3606_Init.o_ErrorParams;

	  FileSysInit(
			  i_FileSysKey:=G_FileSysKeyWord ,
			  i_pStart:= ADR(G_3606_ParameterImage[3]) ,                      (* Image contains footer and header. *)
			  i_pEnd:=  ADR(G_3606_ParameterImage[G_3606_PARAM_SIZE-2]),
			  i_BlockSize:= G_3606_BLOCK_SIZE_FILE_SYS ,
			  o_Error=> G_3606_ErrFileSysInit);
	      G_FileSysDir := G_FileSysFileSystem.Dir;
		   (* Store old ram image changed counter *)
		G_3606_OldImageChanged := G_FileSysFileSystem.RamImageChanged;
		G_InitFlashReady := TRUE;
	END_IF

END_IF

END_STEP
(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Flash TO Init_IO:=
G_InitFlashReady
END_TRANSITION
INITIAL_STEP Init_IO:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
	;
(*IO init:*)
    (* System inits *)
    {{SYSTEM_FW_Version.name}}:=SystemParameters.o_SoftwareVersion;    
    {{SYSTEM_ControlUnitType.name}} := SystemParameters.o_ProductCode;
    {{SYSTEM_ControlUnitRevision.name}} := SystemParameters.o_RevisionNumber;
    {{SYSTEM_SerialNumber.name}} := SystemParameters.o_SerialNumber;
    {{SYSTEM_VendorId.name}} := SystemParameters.o_VendorId;

(* Enabled 5V reference as default *)
    {{REF_OUT_5V_Enable.name}} := TRUE;

(* Init conversion array for supply voltage measurement *)
    {{AiSupplyAiFiltFb.name}}.i_CH:= 3;
    {{AiSupplyAiFiltFb.name}}.i_Data := ADR({{AiSupplyArray.name}});
    {{AiSupplyAiFiltFb.name}}.i_Length := SIZEOF({{AiSupplyArray.name}});
    {{AiSupplyAiFiltFb.name}}();

(* Init conversion array for PCB temperature measurement *)
    {{AiPCBTempAiFiltFb.name}}.i_CH:= 2;
    {{AiPCBTempAiFiltFb.name}}.i_Data := ADR({{AiPCBTempArray.name}});
    {{AiPCBTempAiFiltFb.name}}.i_Length := SIZEOF({{AiPCBTempArray.name}});
    {{AiPCBTempAiFiltFb.name}}();

(* Init conversion array 5V reference voltage measurement *)
    {{AI_Ref5VAiFiltFb.name}}.i_CH:= 0;
    {{AI_Ref5VAiFiltFb.name}}.i_Data := ADR({{AI_Ref5VArray.name}});
    {{AI_Ref5VAiFiltFb.name}}.i_Length := SIZEOF({{AI_Ref5VArray.name}});
    {{AI_Ref5VAiFiltFb.name}}();

(* Init conversion array 2.5V reference voltage  measurement *)
    {{AI_Ref2_5VAiFiltFb.name}}.i_CH:= 1;
