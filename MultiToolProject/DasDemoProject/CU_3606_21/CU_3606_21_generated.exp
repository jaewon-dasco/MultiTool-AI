	LowCalibratedValue:INT := -1800;
	SensorValueErrorLimitHigh:UINT := 480;(* 0.01V *)
	SensorValueErrorLimitLow:UINT := 20;(* 0.01V *)
	CalibratedValueAlarmLimitHigh:INT := 900;
	CalibratedValueWarningLimitHigh:INT := 450;
	CalibratedValueWarningLimitLow:INT := -450;
	CalibratedValueAlarmLimitLow:INT := -900;
	EnableSensorValueErrors:BOOL := 1;(* T/F *)
	EnableCalibratedValueHighAlarm:BOOL := 1;(* T/F *)
	EnableCalibratedValueHighWarning:BOOL := 1;(* T/F *)
	EnableCalibratedValueLowWarning:BOOL := 1;(* T/F *)
	EnableCalibratedValueLowAlarm:BOOL := 1;(* T/F *)
	ErrorDelay:UINT := 1000;(* ms *)
END_STRUCT
END_TYPE
