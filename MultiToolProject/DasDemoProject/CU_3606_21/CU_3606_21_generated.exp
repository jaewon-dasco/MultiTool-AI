INITIAL_STEP Init_Protocols_Can1:
(*#############################################*)
(*This block is created implicit. Don't add own code to here.*)
(*#############################################*)
	;

(*CAN1 INIT*)
(* Sequencer is used to split init to smaller steps *)
CASE CANInitSequencer OF
	0: (* Sequencer step 0*)
¤#CAN#0#¤
		CANInitSequencer := CANInitSequencer + 1;
	1: (* Sequencer step 1*)
¤#MONITORING#0#¤
		CANInitSequencer := CANInitSequencer + 1;
	2: (* Sequencer step 2*)
¤#BASEOD#0#¤
		CANInitSequencer := CANInitSequencer + 1;
	3:  (* Sequencer step 3*)
¤#PDO#0#¤
		CANInitSequencer := CANInitSequencer + 1;
	4:   (* Sequencer step 4*)
¤#J9139_INIT_PROTOCOL#0#¤
		CANInitSequencer := CANInitSequencer + 1;
	5:   (* Sequencer step 5*)
¤#AFTER_CAN_INIT#0#¤	
		CANInitSequencer := CANInitSequencer + 1;
	ELSE
		(* Sequencer ready *)
		G_InitProtocolsCan1Ready:=TRUE;
		CANInitSequencer := 0;
END_CASE	
  
END_STEP

(* @SFCMAXTIME := '' *)
(* @SFCMINTIME := '' *)
(* @SFCCOMMENT := '' *)
TRANSITION FROM Init_Protocols_Can1 TO Init_Protocols_Can2:= 
G_InitProtocolsCan1Ready
END_TRANSITION

